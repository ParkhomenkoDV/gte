									<ml:parens>
										<ml:apply>
											<ml:equal/>
											<ml:id xml:space="preserve">Fuel</ml:id>
											<ml:str xml:space="preserve">Коксовый газ</ml:str>
										</ml:apply>
									</ml:parens>
									<ml:id xml:space="preserve">NaN</ml:id>
								</ml:ifThen>
								<ml:ifThen>
									<ml:parens>
										<ml:apply>
											<ml:equal/>
											<ml:id xml:space="preserve">Fuel</ml:id>
											<ml:str xml:space="preserve">Водород</ml:str>
										</ml:apply>
