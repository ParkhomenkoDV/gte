					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="0" margin-right="0" text-indent="0" text-align="left" list-style-type="none" tabs="inherit">Частота собственных угловых колебаний (Гц) [9, с.243]:</p>
					</text>
				</region>
				<region region-id="553125" left="654" top="2040.75" width="396" height="60.75" align-x="834" align-y="2058" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="угл">ν0</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">mode</ml:id>
									<ml:id xml:space="preserve">bandage</ml:id>
									<ml:id xml:space="preserve">h</ml:id>
									<ml:id xml:space="preserve">G</ml:id>
									<ml:id xml:space="preserve">ρ</ml:id>
									<ml:id xml:space="preserve">stiffness</ml:id>
									<ml:id xml:space="preserve">Jp</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:apply>
								<ml:mult/>
								<ml:apply>
									<ml:sqrt/>
									<ml:apply>
										<ml:div/>
										<ml:apply>
											<ml:mult/>
											<ml:id xml:space="preserve">G</ml:id>
											<ml:id xml:space="preserve">stiffness</ml:id>
										</ml:apply>
										<ml:apply>
											<ml:mult/>
											<ml:id xml:space="preserve">ρ</ml:id>
											<ml:id xml:space="preserve">Jp</ml:id>
										</ml:apply>
									</ml:apply>
								</ml:apply>
								<ml:program>
									<ml:ifThen>
										<ml:apply>
											<ml:equal/>
											<ml:id xml:space="preserve">bandage</ml:id>
											<ml:real>0</ml:real>
										</ml:apply>
										<ml:apply>
											<ml:div/>
											<ml:apply>
												<ml:minus/>
												<ml:apply>
													<ml:mult/>
													<ml:real>2</ml:real>
													<ml:id xml:space="preserve">mode</ml:id>
												</ml:apply>
												<ml:real>1</ml:real>
											</ml:apply>
											<ml:apply>
												<ml:mult/>
												<ml:real>4</ml:real>
												<ml:id xml:space="preserve">h</ml:id>
											</ml:apply>
										</ml:apply>
									</ml:ifThen>
									<ml:otherwise>
										<ml:apply>
											<ml:div/>
											<ml:id xml:space="preserve">mode</ml:id>
											<ml:apply>
												<ml:mult/>
												<ml:real>2</ml:real>
												<ml:id xml:space="preserve">h</ml:id>
											</ml:apply>
