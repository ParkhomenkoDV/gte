											<ml:apply>
												<ml:minus/>
												<ml:real>1</ml:real>
												<ml:apply>
													<ml:id xml:space="preserve">cos</ml:id>
													<ml:apply>
														<ml:indexer/>
														<ml:id xml:space="preserve" subscript="i">β</ml:id>
														<ml:id xml:space="preserve">i</ml:id>
													</ml:apply>
												</ml:apply>
											</ml:apply>
										</ml:localDefine>
										<ml:localDefine>
											<ml:apply>
												<ml:indexer/>
												<ml:id xml:space="preserve" subscript="f">Y</ml:id>
												<ml:id xml:space="preserve">i</ml:id>
											</ml:apply>
											<ml:apply>
												<ml:mult/>
												<ml:id xml:space="preserve">f̅</ml:id>
												<ml:program>
													<ml:ifThen>
														<ml:apply>
															<ml:lessThan/>
															<ml:apply>
																<ml:lessOrEqual/>
																<ml:real>0</ml:real>
																<ml:apply>
																	<ml:indexer/>
																	<ml:id xml:space="preserve" subscript="i">X</ml:id>
																	<ml:id xml:space="preserve">i</ml:id>
																</ml:apply>
															</ml:apply>
															<ml:id xml:space="preserve" subscript="f">x̅</ml:id>
														</ml:apply>
														<ml:apply>
															<ml:mult/>
															<ml:apply>
																<ml:pow/>
																<ml:id xml:space="preserve" subscript="f">x̅</ml:id>
																<ml:real>-2</ml:real>
															</ml:apply>
															<ml:parens>
																<ml:apply>
																	<ml:minus/>
																	<ml:apply>
																		<ml:mult/>
																		<ml:apply>
																			<ml:mult/>
																			<ml:real>2</ml:real>
																			<ml:id xml:space="preserve" subscript="f">x̅</ml:id>
																		</ml:apply>
																		<ml:apply>
																			<ml:indexer/>
																			<ml:id xml:space="preserve" subscript="i">X</ml:id>
																			<ml:id xml:space="preserve">i</ml:id>
																		</ml:apply>
																	</ml:apply>
																	<ml:apply>
																		<ml:pow/>
																		<ml:parens>
																			<ml:apply>
																				<ml:indexer/>
																				<ml:id xml:space="preserve" subscript="i">X</ml:id>
																				<ml:id xml:space="preserve">i</ml:id>
																			</ml:apply>
																		</ml:parens>
																		<ml:real>2</ml:real>
																	</ml:apply>
																</ml:apply>
															</ml:parens>
														</ml:apply>
													</ml:ifThen>
													<ml:ifThen>
														<ml:apply>
															<ml:lessOrEqual/>
															<ml:id xml:space="preserve" subscript="f">x̅</ml:id>
