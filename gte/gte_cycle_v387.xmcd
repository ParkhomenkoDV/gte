												<ml:apply>
													<ml:pow/>
													<ml:parens>
														<ml:apply>
															<ml:minus/>
															<ml:apply>
																<ml:id xml:space="preserve">f_upper</ml:id>
																<ml:id xml:space="preserve">x</ml:id>
															</ml:apply>
															<ml:apply>
																<ml:id xml:space="preserve">f_lower</ml:id>
																<ml:id xml:space="preserve">x</ml:id>
															</ml:apply>
														</ml:apply>
													</ml:parens>
													<ml:real>3</ml:real>
												</ml:apply>
											</ml:lambda>
											<ml:bounds>
												<ml:id xml:space="preserve">x_min</ml:id>
												<ml:id xml:space="preserve">x_max</ml:id>
