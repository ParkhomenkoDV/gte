				<region region-id="516271" left="168" top="6476.25" width="364.5" height="87.75" align-x="240.75" align-y="6498" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve">μ</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">substance</ml:id>
									<ml:id xml:space="preserve">T</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:ifThen>
									<ml:apply>
										<ml:equal/>
										<ml:id xml:space="preserve">substance</ml:id>
										<ml:str xml:space="preserve">воздух</ml:str>
									</ml:apply>
									<ml:apply>
										<ml:mult/>
										<ml:apply>
											<ml:mult/>
											<ml:real>17.16</ml:real>
											<ml:apply>
												<ml:pow/>
												<ml:real>10</ml:real>
												<ml:real>-6</ml:real>
											</ml:apply>
										</ml:apply>
										<ml:apply>
											<ml:pow/>
											<ml:parens>
												<ml:apply>
													<ml:div/>
													<ml:id xml:space="preserve">T</ml:id>
													<ml:real>273.15</ml:real>
												</ml:apply>
											</ml:parens>
											<ml:real>0.68</ml:real>
										</ml:apply>
									</ml:apply>
								</ml:ifThen>
								<ml:ifThen>
									<ml:apply>
										<ml:equal/>
										<ml:id xml:space="preserve">substance</ml:id>
										<ml:str xml:space="preserve">продукты сгорания</ml:str>
									</ml:apply>
									<ml:apply>
										<ml:mult/>
										<ml:apply>
											<ml:mult/>
											<ml:real>13.65</ml:real>
											<ml:apply>
												<ml:pow/>
												<ml:real>10</ml:real>
												<ml:real>-6</ml:real>
											</ml:apply>
										</ml:apply>
										<ml:apply>
											<ml:pow/>
											<ml:parens>
												<ml:apply>
													<ml:div/>
													<ml:id xml:space="preserve">T</ml:id>
													<ml:real>273.15</ml:real>
												</ml:apply>
											</ml:parens>
											<ml:real>0.82</ml:real>
										</ml:apply>
									</ml:apply>
								</ml:ifThen>
								<ml:otherwise>
