				<region region-id="546768" left="6" top="3906" width="363.75" height="75.75" align-x="69.75" align-y="3930" show-border="true" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="(b/t)=1">ε</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve" subscript="outlet">β</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:apply>
								<ml:mult/>
								<ml:id xml:space="preserve">deg</ml:id>
								<ml:program>
									<ml:ifThen>
										<ml:apply>
											<ml:lessOrEqual/>
											<ml:id xml:space="preserve" subscript="outlet">β</ml:id>
											<ml:apply>
												<ml:mult/>
												<ml:real>60</ml:real>
												<ml:id xml:space="preserve">°</ml:id>
											</ml:apply>
										</ml:apply>
										<ml:parens>
											<ml:apply>
												<ml:plus/>
												<ml:apply>
													<ml:minus/>
													<ml:apply>
														<ml:mult/>
														<ml:real>0.005</ml:real>
														<ml:apply>
															<ml:pow/>
															<ml:parens>
																<ml:apply>
																	<ml:div/>
																	<ml:id xml:space="preserve" subscript="outlet">β</ml:id>
																	<ml:id xml:space="preserve">deg</ml:id>
																</ml:apply>
															</ml:parens>
															<ml:real font="0">2</ml:real>
														</ml:apply>
													</ml:apply>
													<ml:apply>
														<ml:mult/>
														<ml:real>0.05</ml:real>
														<ml:parens>
															<ml:apply>
																<ml:div/>
																<ml:id xml:space="preserve" subscript="outlet">β</ml:id>
																<ml:id xml:space="preserve">deg</ml:id>
															</ml:apply>
														</ml:parens>
													</ml:apply>
												</ml:apply>
												<ml:real>5</ml:real>
											</ml:apply>
										</ml:parens>
									</ml:ifThen>
									<ml:otherwise>
										<ml:parens>
											<ml:apply>
												<ml:minus/>
												<ml:apply>
													<ml:plus/>
													<ml:apply>
														<ml:mult/>
														<ml:real>-0.0016</ml:real>
														<ml:apply>
															<ml:pow/>
															<ml:parens>
																<ml:apply>
																	<ml:div/>
																	<ml:id xml:space="preserve" subscript="outlet">β</ml:id>
																	<ml:id xml:space="preserve">deg</ml:id>
																</ml:apply>
															</ml:parens>
															<ml:real font="0">2</ml:real>
														</ml:apply>
													</ml:apply>
													<ml:apply>
														<ml:mult/>
														<ml:real>0.7031</ml:real>
														<ml:parens>
															<ml:apply>
																<ml:div/>
																<ml:id xml:space="preserve" subscript="outlet">β</ml:id>
																<ml:id xml:space="preserve">deg</ml:id>
															</ml:apply>
														</ml:parens>
													</ml:apply>
												</ml:apply>
												<ml:real>16.646</ml:real>
											</ml:apply>
										</ml:parens>
									</ml:otherwise>
								</ml:program>
							</ml:apply>
						</ml:define>
					</math>
