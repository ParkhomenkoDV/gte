				<region region-id="530070" left="858" top="9368.25" width="114" height="33.75" align-x="899.25" align-y="9390" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
