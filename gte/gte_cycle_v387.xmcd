						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:matrix rows="2" cols="1">
								<ml:id xml:space="preserve" subscript="н">P*</ml:id>
								<ml:id xml:space="preserve" subscript="н">P</ml:id>
							</ml:matrix>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:matrix rows="2" cols="1">
									<ml:apply>
										<ml:id xml:space="preserve" subscript="атм">P</ml:id>
										<ml:id xml:space="preserve" subscript="υ">H</ml:id>
									</ml:apply>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="атм">P</ml:id>
										<ml:id xml:space="preserve" subscript="υ">H</ml:id>
