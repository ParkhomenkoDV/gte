									<ml:id xml:space="preserve">ε/ε</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:apply>
								<ml:id xml:space="preserve">interp</ml:id>
								<ml:sequence>
									<ml:apply>
										<ml:id xml:space="preserve">cspline</ml:id>
										<ml:sequence>
											<ml:id xml:space="preserve" subscript=".">ε/ε</ml:id>
											<ml:id xml:space="preserve" subscript=".">b/t=1</ml:id>
										</ml:sequence>
									</ml:apply>
									<ml:id xml:space="preserve" subscript=".">ε/ε</ml:id>
									<ml:id xml:space="preserve" subscript=".">b/t=1</ml:id>
									<ml:id xml:space="preserve">ε/ε</ml:id>
								</ml:sequence>
							</ml:apply>
						</ml:define>
					</math>
				</region>
