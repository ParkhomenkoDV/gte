									<ml:parens>
										<ml:apply>
											<ml:equal/>
											<ml:id xml:space="preserve">Fuel</ml:id>
											<ml:str xml:space="preserve">Бензин</ml:str>
										</ml:apply>
									</ml:parens>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="бензин">Cp</ml:id>
										<ml:id xml:space="preserve">T</ml:id>
									</ml:apply>
								</ml:ifThen>
								<ml:ifThen>
									<ml:parens>
										<ml:apply>
											<ml:equal/>
											<ml:id xml:space="preserve">Fuel</ml:id>
											<ml:str xml:space="preserve">Дизель</ml:str>
										</ml:apply>
									</ml:parens>
									<ml:id xml:space="preserve">NaN</ml:id>
								</ml:ifThen>
								<ml:ifThen>
									<ml:parens>
										<ml:apply>
											<ml:equal/>
											<ml:id xml:space="preserve">Fuel</ml:id>
											<ml:str xml:space="preserve">Мазут</ml:str>
										</ml:apply>
									</ml:parens>
									<ml:id xml:space="preserve">NaN</ml:id>
								</ml:ifThen>
								<ml:ifThen>
									<ml:parens>
										<ml:apply>
											<ml:equal/>
											<ml:id xml:space="preserve">Fuel</ml:id>
											<ml:str xml:space="preserve">Природный газ</ml:str>
										</ml:apply>
									</ml:parens>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="ПГ">Cp</ml:id>
										<ml:id xml:space="preserve">T</ml:id>
									</ml:apply>
