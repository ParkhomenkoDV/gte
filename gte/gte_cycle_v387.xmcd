													<ml:id xml:space="preserve">epsilon</ml:id>
												</ml:apply>
											</ml:apply>
											<ml:break/>
										</ml:ifThen>
									</ml:program>
								</ml:while>
								<ml:localDefine>
									<ml:id xml:space="preserve" subscript="ок3">α</ml:id>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="смешение">α</ml:id>
										<ml:sequence>
											<ml:apply>
												<ml:minus/>
												<ml:id xml:space="preserve" subscript="1">g</ml:id>
												<ml:id xml:space="preserve" subscript="гор">g</ml:id>
											</ml:apply>
											<ml:id xml:space="preserve" subscript="охл">g</ml:id>
											<ml:id xml:space="preserve" subscript="гор">g</ml:id>
											<ml:id xml:space="preserve">Fuel</ml:id>
										</ml:sequence>
									</ml:apply>
								</ml:localDefine>
								<ml:localDefine>
									<ml:id xml:space="preserve" subscript="3">R</ml:id>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="газ">R</ml:id>
										<ml:sequence>
											<ml:id xml:space="preserve" subscript="ок3">α</ml:id>
											<ml:id xml:space="preserve">Fuel</ml:id>
										</ml:sequence>
									</ml:apply>
								</ml:localDefine>
								<ml:localDefine>
									<ml:id xml:space="preserve" subscript="3">P*</ml:id>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="смешение">P</ml:id>
										<ml:sequence>
											<ml:id xml:space="preserve" subscript="РК3">P*</ml:id>
											<ml:apply>
												<ml:plus/>
												<ml:id xml:space="preserve" subscript="1">g</ml:id>
												<ml:apply>
													<ml:mult/>
													<ml:id xml:space="preserve">χ</ml:id>
													<ml:id xml:space="preserve" subscript="охл">g</ml:id>
												</ml:apply>
											</ml:apply>
											<ml:id xml:space="preserve" subscript="охл">P*</ml:id>
											<ml:apply>
												<ml:mult/>
												<ml:parens>
													<ml:apply>
														<ml:minus/>
														<ml:real font="0">1</ml:real>
														<ml:id xml:space="preserve">χ</ml:id>
													</ml:apply>
												</ml:parens>
												<ml:id xml:space="preserve" subscript="охл">g</ml:id>
											</ml:apply>
										</ml:sequence>
									</ml:apply>
								</ml:localDefine>
								<ml:localDefine>
									<ml:id xml:space="preserve" subscript="3">T*</ml:id>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="смешение">T</ml:id>
										<ml:sequence>
											<ml:id xml:space="preserve" subscript="РК3">P*</ml:id>
											<ml:id xml:space="preserve" subscript="РК3">T*</ml:id>
											<ml:apply>
												<ml:plus/>
												<ml:id xml:space="preserve" subscript="1">g</ml:id>
												<ml:apply>
													<ml:mult/>
													<ml:id xml:space="preserve">χ</ml:id>
													<ml:id xml:space="preserve" subscript="охл">g</ml:id>
												</ml:apply>
											</ml:apply>
											<ml:id xml:space="preserve" subscript="РК3">α</ml:id>
											<ml:id xml:space="preserve" subscript="охл">P*</ml:id>
											<ml:id xml:space="preserve" subscript="охл">T*</ml:id>
											<ml:apply>
												<ml:mult/>
												<ml:parens>
													<ml:apply>
														<ml:minus/>
														<ml:real>1</ml:real>
														<ml:id xml:space="preserve">χ</ml:id>
													</ml:apply>
												</ml:parens>
												<ml:id xml:space="preserve" subscript="охл">g</ml:id>
											</ml:apply>
											<ml:id xml:space="preserve" subscript="ок3">α</ml:id>
											<ml:id xml:space="preserve">Fuel</ml:id>
										</ml:sequence>
									</ml:apply>
								</ml:localDefine>
								<ml:localDefine>
									<ml:id xml:space="preserve" subscript="3">Cp</ml:id>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="газ">Cp</ml:id>
										<ml:sequence>
											<ml:id xml:space="preserve" subscript="3">P*</ml:id>
											<ml:id xml:space="preserve" subscript="3">T*</ml:id>
											<ml:id xml:space="preserve" subscript="ок3">α</ml:id>
											<ml:id xml:space="preserve">Fuel</ml:id>
										</ml:sequence>
									</ml:apply>
								</ml:localDefine>
								<ml:localDefine>
									<ml:id xml:space="preserve" subscript="3">k</ml:id>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="ад">k</ml:id>
										<ml:sequence>
											<ml:id xml:space="preserve" subscript="3">Cp</ml:id>
											<ml:apply>
												<ml:id xml:space="preserve" subscript="газ">R</ml:id>
												<ml:sequence>
													<ml:id xml:space="preserve" subscript="ок3">α</ml:id>
													<ml:id xml:space="preserve">Fuel</ml:id>
												</ml:sequence>
											</ml:apply>
										</ml:sequence>
									</ml:apply>
								</ml:localDefine>
								<ml:apply>
									<ml:transpose/>
									<ml:matrix rows="1" cols="8">
										<ml:id xml:space="preserve">iteration</ml:id>
										<ml:id xml:space="preserve" subscript="ок3">α</ml:id>
										<ml:id xml:space="preserve" subscript="3">R</ml:id>
										<ml:id xml:space="preserve" subscript="3">T*</ml:id>
										<ml:id xml:space="preserve" subscript="3">P*</ml:id>
										<ml:id xml:space="preserve" subscript="3">Cp</ml:id>
										<ml:id xml:space="preserve" subscript="3">k</ml:id>
										<ml:id xml:space="preserve">π*</ml:id>
									</ml:matrix>
								</ml:apply>
							</ml:program>
						</ml:define>
					</math>
				</region>
				<region region-id="508352" left="0" top="8628" width="6000" height="6" align-x="0" align-y="8628" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<pageBreak/>
