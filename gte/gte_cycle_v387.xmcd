				<region region-id="530064" left="6" top="9387" width="487.5" height="121.5" align-x="93" align-y="9396" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="трение">ξ</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve" subscript="inlet">γ</ml:id>
									<ml:id xml:space="preserve" subscript="outlet">γ</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:localDefine>
									<ml:id xml:space="preserve">x</ml:id>
									<ml:program>
										<ml:ifThen>
											<ml:apply>
												<ml:lessOrEqual/>
												<ml:apply>
													<ml:plus/>
													<ml:id xml:space="preserve" subscript="inlet">γ</ml:id>
													<ml:id xml:space="preserve" subscript="outlet">γ</ml:id>
												</ml:apply>
												<ml:apply>
													<ml:mult style="auto-select"/>
													<ml:real>110</ml:real>
													<ml:id xml:space="preserve">°</ml:id>
												</ml:apply>
											</ml:apply>
											<ml:apply>
												<ml:plus/>
												<ml:id xml:space="preserve" subscript="inlet">γ</ml:id>
												<ml:id xml:space="preserve" subscript="outlet">γ</ml:id>
											</ml:apply>
										</ml:ifThen>
										<ml:otherwise>
											<ml:apply>
												<ml:mult style="auto-select"/>
												<ml:real>110</ml:real>
												<ml:id xml:space="preserve">°</ml:id>
											</ml:apply>
										</ml:otherwise>
									</ml:program>
								</ml:localDefine>
								<ml:localDefine>
									<ml:id xml:space="preserve">y</ml:id>
									<ml:program>
										<ml:ifThen>
											<ml:apply>
												<ml:lessOrEqual/>
												<ml:apply>
													<ml:div/>
													<ml:apply>
														<ml:id xml:space="preserve">sin</ml:id>
														<ml:id xml:space="preserve" subscript="inlet">γ</ml:id>
													</ml:apply>
													<ml:apply>
														<ml:id xml:space="preserve">sin</ml:id>
														<ml:id xml:space="preserve" subscript="outlet">γ</ml:id>
													</ml:apply>
												</ml:apply>
												<ml:real>1.7</ml:real>
											</ml:apply>
											<ml:apply>
												<ml:div/>
												<ml:apply>
													<ml:id xml:space="preserve">sin</ml:id>
													<ml:id xml:space="preserve" subscript="inlet">γ</ml:id>
												</ml:apply>
												<ml:apply>
													<ml:id xml:space="preserve">sin</ml:id>
													<ml:id xml:space="preserve" subscript="outlet">γ</ml:id>
												</ml:apply>
											</ml:apply>
										</ml:ifThen>
										<ml:otherwise>
											<ml:real>1.7</ml:real>
