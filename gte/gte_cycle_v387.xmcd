														<ml:mult/>
														<ml:real>0.7031</ml:real>
														<ml:parens>
															<ml:apply>
																<ml:div/>
																<ml:id xml:space="preserve" subscript="outlet">β</ml:id>
																<ml:id xml:space="preserve">deg</ml:id>
															</ml:apply>
														</ml:parens>
													</ml:apply>
												</ml:apply>
												<ml:real>16.646</ml:real>
											</ml:apply>
										</ml:parens>
									</ml:otherwise>
								</ml:program>
							</ml:apply>
						</ml:define>
