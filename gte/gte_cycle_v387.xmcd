							<ml:program>
								<ml:ifThen>
									<ml:apply>
										<ml:greaterThan/>
										<ml:id xml:space="preserve" subscript="u">υ</ml:id>
										<ml:real>0</ml:real>
									</ml:apply>
									<ml:apply>
										<ml:id xml:space="preserve">atan</ml:id>
										<ml:apply>
											<ml:div/>
											<ml:id xml:space="preserve" subscript="a">υ</ml:id>
											<ml:id xml:space="preserve" subscript="u">υ</ml:id>
										</ml:apply>
									</ml:apply>
								</ml:ifThen>
								<ml:ifThen>
									<ml:apply>
										<ml:equal/>
										<ml:id xml:space="preserve" subscript="u">υ</ml:id>
										<ml:real>0</ml:real>
									</ml:apply>
									<ml:apply>
										<ml:mult/>
										<ml:real>0.5</ml:real>
										<ml:id xml:space="preserve">π</ml:id>
									</ml:apply>
								</ml:ifThen>
								<ml:ifThen>
									<ml:apply>
										<ml:lessThan/>
										<ml:id xml:space="preserve" subscript="u">υ</ml:id>
										<ml:real>0</ml:real>
									</ml:apply>
									<ml:apply>
										<ml:plus/>
										<ml:id xml:space="preserve">π</ml:id>
										<ml:apply>
											<ml:id xml:space="preserve">atan</ml:id>
											<ml:apply>
												<ml:div/>
												<ml:id xml:space="preserve" subscript="a">υ</ml:id>
												<ml:id xml:space="preserve" subscript="u">υ</ml:id>
											</ml:apply>
										</ml:apply>
									</ml:apply>
								</ml:ifThen>
							</ml:program>
						</ml:define>
