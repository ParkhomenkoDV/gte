				<region region-id="530076" left="6" top="9666" width="225" height="30" align-x="123.75" align-y="9684" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
