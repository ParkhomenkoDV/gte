									<ml:id xml:space="preserve">type</ml:id>
									<ml:id xml:space="preserve">x0</ml:id>
									<ml:id xml:space="preserve">x1</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:ifThen>
									<ml:apply>
										<ml:equal/>
										<ml:id xml:space="preserve">type</ml:id>
										<ml:str xml:space="preserve">rel</ml:str>
									</ml:apply>
									<ml:program>
										<ml:ifThen>
											<ml:apply>
												<ml:notEqual/>
												<ml:id xml:space="preserve">x0</ml:id>
												<ml:real>0</ml:real>
											</ml:apply>
											<ml:apply>
												<ml:div/>
												<ml:apply>
													<ml:minus/>
													<ml:id xml:space="preserve">x1</ml:id>
													<ml:id xml:space="preserve">x0</ml:id>
												</ml:apply>
												<ml:id xml:space="preserve">x0</ml:id>
											</ml:apply>
										</ml:ifThen>
										<ml:otherwise>
											<ml:id xml:space="preserve">∞</ml:id>
										</ml:otherwise>
									</ml:program>
								</ml:ifThen>
								<ml:ifThen>
									<ml:apply>
										<ml:equal/>
										<ml:id xml:space="preserve">type</ml:id>
										<ml:str xml:space="preserve">abs</ml:str>
									</ml:apply>
									<ml:apply>
										<ml:minus/>
										<ml:id xml:space="preserve">x1</ml:id>
										<ml:id xml:space="preserve">x0</ml:id>
									</ml:apply>
								</ml:ifThen>
							</ml:program>
						</ml:define>
					</math>
				</region>
				<region region-id="556411" left="624" top="390.75" width="135" height="14.25" align-x="649.5" align-y="402" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Расстоние между точками:</p>
					</text>
				</region>
				<region region-id="556412" left="624" top="415.5" width="208.5" height="20.25" align-x="721.5" align-y="432" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve">distance</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">x1</ml:id>
									<ml:id xml:space="preserve">y1</ml:id>
									<ml:id xml:space="preserve">x2</ml:id>
									<ml:id xml:space="preserve">y2</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:apply>
								<ml:sqrt/>
								<ml:apply>
									<ml:plus/>
									<ml:apply>
										<ml:pow/>
										<ml:parens>
											<ml:apply>
												<ml:minus/>
												<ml:id xml:space="preserve">x2</ml:id>
												<ml:id xml:space="preserve">x1</ml:id>
											</ml:apply>
										</ml:parens>
										<ml:real>2</ml:real>
									</ml:apply>
									<ml:apply>
										<ml:pow/>
										<ml:parens>
											<ml:apply>
												<ml:minus/>
												<ml:id xml:space="preserve">y2</ml:id>
												<ml:id xml:space="preserve">y1</ml:id>
											</ml:apply>
										</ml:parens>
										<ml:real>2</ml:real>
									</ml:apply>
								</ml:apply>
							</ml:apply>
						</ml:define>
					</math>
				</region>
				<region region-id="556413" left="624" top="450.75" width="162.75" height="14.25" align-x="652.5" align-y="462" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Расстояние от точки до прямой:</p>
					</text>
				</region>
				<region region-id="556414" left="624" top="482.25" width="222" height="35.25" align-x="746.25" align-y="498" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve">distance2line</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">x0</ml:id>
									<ml:id xml:space="preserve">y0</ml:id>
									<ml:id xml:space="preserve">A</ml:id>
									<ml:id xml:space="preserve">B</ml:id>
									<ml:id xml:space="preserve">C</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:apply>
								<ml:div/>
								<ml:apply>
									<ml:absval/>
									<ml:apply>
										<ml:plus/>
										<ml:apply>
											<ml:plus/>
											<ml:apply>
												<ml:mult/>
												<ml:id xml:space="preserve">A</ml:id>
												<ml:id xml:space="preserve">x0</ml:id>
											</ml:apply>
											<ml:apply>
												<ml:mult/>
												<ml:id xml:space="preserve">B</ml:id>
												<ml:id xml:space="preserve">y0</ml:id>
											</ml:apply>
										</ml:apply>
										<ml:id xml:space="preserve">C</ml:id>
									</ml:apply>
								</ml:apply>
								<ml:apply>
									<ml:sqrt/>
									<ml:apply>
										<ml:plus/>
										<ml:apply>
											<ml:pow/>
											<ml:id xml:space="preserve">A</ml:id>
											<ml:real>2</ml:real>
										</ml:apply>
										<ml:apply>
											<ml:pow/>
											<ml:id xml:space="preserve">B</ml:id>
											<ml:real>2</ml:real>
										</ml:apply>
									</ml:apply>
								</ml:apply>
							</ml:apply>
						</ml:define>
					</math>
				</region>
				<region region-id="517989" left="6" top="510.75" width="120.75" height="14.25" align-x="20.25" align-y="522" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Целая часть от деления:</p>
					</text>
				</region>
				<region region-id="517990" left="138" top="506.25" width="249.75" height="27.75" align-x="234" align-y="522" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve">div</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">dividend</ml:id>
									<ml:id xml:space="preserve">divider</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:apply>
								<ml:div/>
								<ml:apply>
									<ml:minus/>
									<ml:id xml:space="preserve">dividend</ml:id>
									<ml:apply>
										<ml:id xml:space="preserve">mod</ml:id>
										<ml:sequence>
											<ml:id xml:space="preserve">dividend</ml:id>
											<ml:id xml:space="preserve">divider</ml:id>
										</ml:sequence>
									</ml:apply>
								</ml:apply>
								<ml:id xml:space="preserve">divider</ml:id>
							</ml:apply>
						</ml:define>
					</math>
				</region>
				<region region-id="556415" left="624" top="534.75" width="139.5" height="14.25" align-x="638.25" align-y="546" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Точка пересечения прямых:</p>
					</text>
				</region>
				<region region-id="518009" left="192" top="555" width="303" height="15" align-x="300.75" align-y="564" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="x">axis</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">x</ml:id>
									<ml:id xml:space="preserve">y</ml:id>
									<ml:id xml:space="preserve">xc</ml:id>
									<ml:id xml:space="preserve">yc</ml:id>
									<ml:id xml:space="preserve">α</ml:id>
									<ml:id xml:space="preserve">scale</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:apply>
								<ml:mult/>
								<ml:parens>
									<ml:apply>
										<ml:plus/>
										<ml:apply>
											<ml:mult/>
											<ml:parens>
												<ml:apply>
													<ml:minus/>
													<ml:id xml:space="preserve">x</ml:id>
													<ml:id xml:space="preserve">xc</ml:id>
												</ml:apply>
											</ml:parens>
											<ml:apply>
												<ml:id xml:space="preserve">cos</ml:id>
												<ml:id xml:space="preserve">α</ml:id>
											</ml:apply>
										</ml:apply>
										<ml:apply>
											<ml:mult/>
											<ml:parens>
												<ml:apply>
													<ml:minus/>
													<ml:id xml:space="preserve">y</ml:id>
													<ml:id xml:space="preserve">yc</ml:id>
												</ml:apply>
											</ml:parens>
											<ml:apply>
												<ml:id xml:space="preserve">sin</ml:id>
												<ml:id xml:space="preserve">α</ml:id>
											</ml:apply>
										</ml:apply>
									</ml:apply>
								</ml:parens>
								<ml:id xml:space="preserve">scale</ml:id>
							</ml:apply>
						</ml:define>
					</math>
				</region>
				<region region-id="518010" left="6" top="558.75" width="174" height="28.5" align-x="30" align-y="570" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Матрица переноса-поворота осей </p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">в точку против часовой стрелки:</p>
					</text>
				</region>
				<region region-id="518011" left="192" top="579" width="308.25" height="15" align-x="300.75" align-y="588" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="y">axis</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">x</ml:id>
									<ml:id xml:space="preserve">y</ml:id>
									<ml:id xml:space="preserve">xc</ml:id>
									<ml:id xml:space="preserve">yc</ml:id>
									<ml:id xml:space="preserve">α</ml:id>
									<ml:id xml:space="preserve">scale</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:apply>
								<ml:mult/>
								<ml:parens>
									<ml:apply>
										<ml:plus/>
										<ml:apply>
											<ml:mult/>
											<ml:apply>
												<ml:neg/>
												<ml:parens>
													<ml:apply>
														<ml:minus/>
														<ml:id xml:space="preserve">x</ml:id>
														<ml:id xml:space="preserve">xc</ml:id>
													</ml:apply>
												</ml:parens>
											</ml:apply>
											<ml:apply>
												<ml:id xml:space="preserve">sin</ml:id>
												<ml:id xml:space="preserve">α</ml:id>
											</ml:apply>
										</ml:apply>
										<ml:apply>
											<ml:mult/>
											<ml:parens>
												<ml:apply>
													<ml:minus/>
													<ml:id xml:space="preserve">y</ml:id>
													<ml:id xml:space="preserve">yc</ml:id>
												</ml:apply>
											</ml:parens>
											<ml:apply>
												<ml:id xml:space="preserve">cos</ml:id>
												<ml:id xml:space="preserve">α</ml:id>
											</ml:apply>
										</ml:apply>
									</ml:apply>
								</ml:parens>
								<ml:id xml:space="preserve">scale</ml:id>
							</ml:apply>
						</ml:define>
					</math>
				</region>
				<region region-id="556416" left="624" top="567.75" width="277.5" height="92.25" align-x="753" align-y="600" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve">COOR</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">A1</ml:id>
									<ml:id xml:space="preserve">B1</ml:id>
									<ml:id xml:space="preserve">C1</ml:id>
									<ml:id xml:space="preserve">A2</ml:id>
									<ml:id xml:space="preserve">B2</ml:id>
									<ml:id xml:space="preserve">C2</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:localDefine>
									<ml:matrix rows="2" cols="1">
										<ml:id xml:space="preserve">x</ml:id>
										<ml:id xml:space="preserve">y</ml:id>
									</ml:matrix>
									<ml:matrix rows="2" cols="1">
										<ml:apply>
											<ml:div/>
											<ml:apply>
												<ml:minus/>
												<ml:id xml:space="preserve">C1</ml:id>
												<ml:id xml:space="preserve">C2</ml:id>
											</ml:apply>
											<ml:apply>
												<ml:minus/>
												<ml:id xml:space="preserve">A2</ml:id>
												<ml:id xml:space="preserve">A1</ml:id>
											</ml:apply>
										</ml:apply>
										<ml:apply>
											<ml:div/>
											<ml:apply>
												<ml:minus/>
												<ml:apply>
													<ml:mult/>
													<ml:id xml:space="preserve">A2</ml:id>
													<ml:id xml:space="preserve">C1</ml:id>
												</ml:apply>
												<ml:apply>
													<ml:mult/>
													<ml:id xml:space="preserve">A1</ml:id>
													<ml:id xml:space="preserve">C2</ml:id>
												</ml:apply>
											</ml:apply>
											<ml:apply>
												<ml:minus/>
												<ml:id xml:space="preserve">A2</ml:id>
												<ml:id xml:space="preserve">A1</ml:id>
											</ml:apply>
										</ml:apply>
									</ml:matrix>
								</ml:localDefine>
								<ml:matrix rows="2" cols="1">
									<ml:id xml:space="preserve">x</ml:id>
									<ml:id xml:space="preserve">y</ml:id>
								</ml:matrix>
							</ml:program>
						</ml:define>
					</math>
				</region>
				<region region-id="518027" left="6" top="618.75" width="218.25" height="28.5" align-x="10.5" align-y="630" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Ф-я номера сечения по номеру ступени (i) </p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">и положению сечения в ступени (j):</p>
					</text>
				</region>
				<region region-id="518028" left="234" top="621" width="126" height="62.25" align-x="266.25" align-y="630" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve">st</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">i</ml:id>
									<ml:id xml:space="preserve">j</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:ifThen>
									<ml:apply>
										<ml:equal/>
										<ml:id xml:space="preserve">j</ml:id>
										<ml:real>1</ml:real>
									</ml:apply>
									<ml:apply>
										<ml:minus/>
										<ml:apply>
											<ml:mult/>
											<ml:real>2</ml:real>
											<ml:id xml:space="preserve">i</ml:id>
										</ml:apply>
										<ml:real>1</ml:real>
									</ml:apply>
								</ml:ifThen>
								<ml:ifThen>
									<ml:apply>
										<ml:equal/>
										<ml:id xml:space="preserve">j</ml:id>
										<ml:real>2</ml:real>
									</ml:apply>
									<ml:apply>
										<ml:mult/>
										<ml:real>2</ml:real>
										<ml:id xml:space="preserve">i</ml:id>
									</ml:apply>
								</ml:ifThen>
								<ml:ifThen>
									<ml:apply>
										<ml:equal/>
										<ml:id xml:space="preserve">j</ml:id>
										<ml:real>3</ml:real>
									</ml:apply>
									<ml:apply>
										<ml:plus/>
										<ml:apply>
											<ml:mult/>
											<ml:real>2</ml:real>
											<ml:id xml:space="preserve">i</ml:id>
										</ml:apply>
										<ml:real>1</ml:real>
									</ml:apply>
								</ml:ifThen>
								<ml:otherwise>
									<ml:id xml:space="preserve">NaN</ml:id>
								</ml:otherwise>
							</ml:program>
						</ml:define>
					</math>
				</region>
				<region region-id="518053" left="6" top="666.75" width="82.5" height="14.25" align-x="14.25" align-y="678" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Ф-я ср. сечения:</p>
					</text>
				</region>
				<region region-id="518054" left="96" top="669" width="86.25" height="15" align-x="130.5" align-y="678" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve">av</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve" subscript="r">N</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:apply>
								<ml:id xml:space="preserve">ceil</ml:id>
								<ml:apply>
									<ml:mult style="auto-select"/>
									<ml:real font="0">0.5</ml:real>
									<ml:id xml:space="preserve" subscript="r">N</ml:id>
								</ml:apply>
							</ml:apply>
						</ml:define>
					</math>
				</region>
				<region region-id="556417" left="624" top="690.75" width="121.5" height="14.25" align-x="663" align-y="702" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Коэффициенты прямой:</p>
					</text>
				</region>
				<region region-id="529251" left="6" top="708.75" width="207.75" height="14.25" align-x="18" align-y="720" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Угол между проекциями скоростей [рад]:</p>
					</text>
				</region>
