					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="installation">υ</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">k</ml:id>
									<ml:id xml:space="preserve" subscript="inlet">υ</ml:id>
									<ml:id xml:space="preserve" subscript="outlet">υ</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:ifThen>
									<ml:apply>
										<ml:greaterThan/>
										<ml:id xml:space="preserve" subscript="inlet">υ</ml:id>
										<ml:apply>
											<ml:div/>
											<ml:id xml:space="preserve">π</ml:id>
											<ml:real>2</ml:real>
										</ml:apply>
									</ml:apply>
									<ml:localDefine>
										<ml:id xml:space="preserve" subscript="inlet">υ</ml:id>
										<ml:apply>
											<ml:minus/>
											<ml:id xml:space="preserve">π</ml:id>
											<ml:id xml:space="preserve" subscript="inlet">υ</ml:id>
										</ml:apply>
