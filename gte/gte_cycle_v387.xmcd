			<area is-collapsed="true" name="Параметры расчета" show-name="true" show-border="true" show-icon="true" show-timestamp="true" allow-expand="false" is-locked="false" timestamp="" top-lock-id="546956" bottom-lock-id="546966">
				<region region-id="547267" left="6" top="36" width="162.75" height="15" align-x="29.25" align-y="48" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Точность сходимости итераций:</p>
					</text>
				</region>
				<region region-id="547268" left="180" top="39" width="54.75" height="12.75" align-x="214.5" align-y="48" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#ffff80" tag="">
					<math optimize="false" disable-calc="false">
						<ml:globalDefine xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve">epsilon</ml:id>
							<ml:apply>
								<ml:mult style="auto-select"/>
