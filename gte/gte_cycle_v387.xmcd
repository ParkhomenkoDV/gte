				<region region-id="547191" left="6" top="72" width="81" height="15" align-x="45" align-y="84" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Дискритизация:</p>
					</text>
				</region>
				<region region-id="547192" left="96" top="75" width="131.25" height="33.75" align-x="117.75" align-y="84" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:globalDefine xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="dis">N</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:program>
									<ml:localDefine>
										<ml:id xml:space="preserve" subscript="dis">N</ml:id>
										<ml:real>41</ml:real>
									</ml:localDefine>
									<ml:ifThen>
										<ml:apply>
											<ml:lessThan/>
											<ml:id xml:space="preserve" subscript="dis">N</ml:id>
											<ml:real>20</ml:real>
										</ml:apply>
										<ml:real>20</ml:real>
									</ml:ifThen>
								</ml:program>
							</ml:eval>
						</ml:globalDefine>
						<resultFormat numeric-only="true">
							<decimal precision="0" show-trailing-zeros="true" radix="dec" complex-threshold="10" zero-threshold="15" imaginary-value="i"/>
							<matrix display-style="table" expand-nested-arrays="false"/>
							<unit format-units="false" simplify-units="false" fractional-unit-exponent="false"/>
						</resultFormat>
					</math>
				</region>
				<region region-id="547193" left="6" top="138" width="189" height="30" align-x="25.5" align-y="150" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Частота дискритизации по высоте Л:</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">(нечетное число)</p>
					</text>
				</region>
				<region region-id="547194" left="204" top="141" width="187.5" height="71.25" align-x="221.25" align-y="150" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="r">N</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:program>
									<ml:localDefine>
										<ml:id xml:space="preserve" subscript="r">N</ml:id>
										<ml:real>3</ml:real>
									</ml:localDefine>
									<ml:localDefine>
										<ml:id xml:space="preserve" subscript="r">N</ml:id>
										<ml:program>
											<ml:ifThen>
												<ml:apply>
													<ml:equal/>
													<ml:apply>
														<ml:id xml:space="preserve">mod</ml:id>
														<ml:sequence>
															<ml:id xml:space="preserve" subscript="r">N</ml:id>
															<ml:real>2</ml:real>
														</ml:sequence>
													</ml:apply>
													<ml:real>1</ml:real>
												</ml:apply>
												<ml:id xml:space="preserve" subscript="r">N</ml:id>
											</ml:ifThen>
											<ml:otherwise>
												<ml:parens>
													<ml:apply>
														<ml:plus/>
														<ml:id xml:space="preserve" subscript="r">N</ml:id>
														<ml:real>1</ml:real>
													</ml:apply>
												</ml:parens>
											</ml:otherwise>
										</ml:program>
									</ml:localDefine>
									<ml:ifThen>
										<ml:apply>
											<ml:lessThan/>
											<ml:id xml:space="preserve" subscript="r">N</ml:id>
											<ml:real>3</ml:real>
										</ml:apply>
										<ml:real>3</ml:real>
									</ml:ifThen>
								</ml:program>
							</ml:eval>
						</ml:define>
						<resultFormat numeric-only="true">
							<decimal precision="0" show-trailing-zeros="true" radix="dec" complex-threshold="10" zero-threshold="15" imaginary-value="i"/>
							<matrix display-style="table" expand-nested-arrays="false"/>
							<unit format-units="false" simplify-units="false" fractional-unit-exponent="false"/>
						</resultFormat>
					</math>
				</region>
