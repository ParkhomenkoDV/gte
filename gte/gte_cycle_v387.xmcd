					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="ад">k</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">Cp</ml:id>
									<ml:id xml:space="preserve">R</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:apply>
								<ml:div/>
								<ml:id xml:space="preserve">Cp</ml:id>
								<ml:apply>
									<ml:minus/>
									<ml:id xml:space="preserve">Cp</ml:id>
									<ml:id xml:space="preserve">R</ml:id>
