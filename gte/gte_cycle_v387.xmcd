														<ml:real>0.01065</ml:real>
														<ml:apply>
															<ml:pow/>
															<ml:parens>
																<ml:apply>
																	<ml:div/>
																	<ml:id xml:space="preserve">x</ml:id>
																	<ml:id xml:space="preserve">deg</ml:id>
																</ml:apply>
															</ml:parens>
															<ml:real>2</ml:real>
														</ml:apply>
													</ml:apply>
													<ml:apply>
														<ml:mult/>
														<ml:real>2.295</ml:real>
														<ml:parens>
															<ml:apply>
																<ml:div/>
																<ml:id xml:space="preserve">x</ml:id>
																<ml:id xml:space="preserve">deg</ml:id>
															</ml:apply>
														</ml:parens>
													</ml:apply>
												</ml:apply>
												<ml:real>160.5</ml:real>
											</ml:apply>
										</ml:parens>
									</ml:apply>
									<ml:parens>
										<ml:apply>
											<ml:plus/>
											<ml:apply>
												<ml:minus/>
												<ml:apply>
													<ml:mult/>
													<ml:real>0.1055</ml:real>
													<ml:apply>
														<ml:pow/>
														<ml:parens>
															<ml:id xml:space="preserve">y</ml:id>
														</ml:parens>
														<ml:real>2</ml:real>
													</ml:apply>
												</ml:apply>
												<ml:apply>
													<ml:mult/>
													<ml:real>0.3427</ml:real>
													<ml:parens>
														<ml:id xml:space="preserve">y</ml:id>
													</ml:parens>
												</ml:apply>
											</ml:apply>
											<ml:real>0.295</ml:real>
										</ml:apply>
									</ml:parens>
								</ml:apply>
							</ml:program>
						</ml:define>
					</math>
