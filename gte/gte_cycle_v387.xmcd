											</ml:apply>
											<ml:apply>
												<ml:mult/>
												<ml:real>4</ml:real>
												<ml:apply>
													<ml:pow/>
													<ml:parens>
														<ml:id xml:space="preserve">Jxy0</ml:id>
													</ml:parens>
