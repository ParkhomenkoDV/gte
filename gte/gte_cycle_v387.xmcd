				<region region-id="530079" left="6" top="9714.75" width="379.5" height="14.25" align-x="24" align-y="9726" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Потери смешения [Абрамович В.И. Прикладная газовая динамика ч.1]:</p>
					</text>
				</region>
				<region region-id="530307" left="696" top="9726.75" width="260.25" height="14.25" align-x="720" align-y="9738" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Поправка на сжимаемость [ГОСТ Р 58990-2020]:</p>
					</text>
				</region>
				<region region-id="530080" left="6" top="9741" width="288.75" height="65.25" align-x="94.5" align-y="9750" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="смешение">ξ</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">type</ml:id>
									<ml:id xml:space="preserve" subscript="охл">g</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:localDefine>
									<ml:id xml:space="preserve" subscript="охл">c̅</ml:id>
									<ml:program>
										<ml:ifThen>
											<ml:apply>
												<ml:equal/>
												<ml:id xml:space="preserve">type</ml:id>
												<ml:str xml:space="preserve">СА</ml:str>
											</ml:apply>
											<ml:apply>
												<ml:id xml:space="preserve">mean</ml:id>
												<ml:sequence>
													<ml:real>0.4</ml:real>
													<ml:real>0.5</ml:real>
												</ml:sequence>
											</ml:apply>
										</ml:ifThen>
										<ml:ifThen>
											<ml:apply>
												<ml:equal/>
												<ml:id xml:space="preserve">type</ml:id>
												<ml:str xml:space="preserve">РК</ml:str>
											</ml:apply>
											<ml:apply>
												<ml:id xml:space="preserve">mean</ml:id>
												<ml:sequence>
													<ml:real>0.4</ml:real>
													<ml:real>0.55</ml:real>
												</ml:sequence>
											</ml:apply>
										</ml:ifThen>
									</ml:program>
								</ml:localDefine>
								<ml:apply>
									<ml:mult/>
									<ml:apply>
										<ml:div/>
										<ml:id xml:space="preserve" subscript="охл">g</ml:id>
										<ml:apply>
											<ml:plus/>
											<ml:real>1</ml:real>
											<ml:id xml:space="preserve" subscript="охл">g</ml:id>
										</ml:apply>
									</ml:apply>
									<ml:apply>
										<ml:pow/>
										<ml:parens>
											<ml:apply>
												<ml:minus/>
												<ml:real>1</ml:real>
												<ml:id xml:space="preserve" subscript="охл">c̅</ml:id>
											</ml:apply>
										</ml:parens>
										<ml:real>2</ml:real>
									</ml:apply>
								</ml:apply>
							</ml:program>
						</ml:define>
					</math>
				</region>
				<region region-id="530308" left="696" top="9753" width="327" height="261" align-x="784.5" align-y="9762" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="сжимаемость">ξ</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">type</ml:id>
									<ml:id xml:space="preserve">λ</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:localDefine>
									<ml:id xml:space="preserve" subscript="опт">λ</ml:id>
									<ml:program>
										<ml:ifThen>
											<ml:apply>
												<ml:equal/>
												<ml:id xml:space="preserve">type</ml:id>
												<ml:str xml:space="preserve">СА</ml:str>
											</ml:apply>
											<ml:real>0.9</ml:real>
										</ml:ifThen>
										<ml:ifThen>
											<ml:apply>
												<ml:equal/>
												<ml:id xml:space="preserve">type</ml:id>
												<ml:str xml:space="preserve">РК</ml:str>
											</ml:apply>
											<ml:real>0.8</ml:real>
										</ml:ifThen>
									</ml:program>
								</ml:localDefine>
								<ml:localDefine>
									<ml:matrix rows="2" cols="1">
										<ml:id xml:space="preserve" subscript="1">a</ml:id>
										<ml:id xml:space="preserve" subscript="2">a</ml:id>
									</ml:matrix>
									<ml:program>
										<ml:ifThen>
											<ml:apply>
												<ml:and/>
												<ml:parens>
													<ml:apply>
														<ml:equal/>
