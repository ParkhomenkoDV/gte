											<ml:apply>
												<ml:nthRoot/>
												<ml:real>3</ml:real>
												<ml:apply>
													<ml:mult/>
													<ml:apply>
														<ml:div/>
														<ml:real>180</ml:real>
														<ml:apply>
															<ml:minus/>
															<ml:real>180</ml:real>
															<ml:parens>
																<ml:apply>
																	<ml:plus/>
																	<ml:apply>
																		<ml:div/>
																		<ml:id xml:space="preserve" subscript="inlet">γ</ml:id>
																		<ml:id xml:space="preserve">deg</ml:id>
																	</ml:apply>
																	<ml:apply>
																		<ml:div/>
																		<ml:id xml:space="preserve" subscript="outlet">γ</ml:id>
																		<ml:id xml:space="preserve">deg</ml:id>
																	</ml:apply>
																</ml:apply>
															</ml:parens>
														</ml:apply>
													</ml:apply>
													<ml:apply>
														<ml:div/>
