				<region region-id="530075" left="6" top="9636.75" width="273.75" height="14.25" align-x="34.5" align-y="9648" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Вторичные потери [1, c. 131, ГОСТ 58990-2020]:</p>
					</text>
