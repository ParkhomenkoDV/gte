				<region region-id="509227" left="6" top="5778.75" width="145.5" height="14.25" align-x="53.25" align-y="5790" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Газодинамические ф-и ГДФ:</p>
					</text>
				</region>
				<region region-id="509228" left="6" top="5810.25" width="402" height="201.75" align-x="101.25" align-y="5826" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve">ГДФ</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">parameter</ml:id>
									<ml:id xml:space="preserve">λ</ml:id>
									<ml:id xml:space="preserve">k</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:ifThen>
									<ml:apply>
										<ml:equal/>
										<ml:id xml:space="preserve">parameter</ml:id>
										<ml:str xml:space="preserve">T</ml:str>
									</ml:apply>
									<ml:return>
										<ml:parens>
											<ml:apply>
												<ml:minus/>
												<ml:real>1</ml:real>
												<ml:apply>
													<ml:mult/>
													<ml:apply>
														<ml:pow/>
														<ml:id xml:space="preserve">λ</ml:id>
														<ml:real>2</ml:real>
													</ml:apply>
													<ml:apply>
														<ml:div/>
														<ml:apply>
															<ml:minus/>
															<ml:id xml:space="preserve">k</ml:id>
															<ml:real>1</ml:real>
														</ml:apply>
														<ml:apply>
															<ml:plus/>
															<ml:id xml:space="preserve">k</ml:id>
															<ml:real>1</ml:real>
														</ml:apply>
													</ml:apply>
												</ml:apply>
											</ml:apply>
										</ml:parens>
									</ml:return>
								</ml:ifThen>
								<ml:ifThen>
									<ml:apply>
										<ml:equal/>
										<ml:id xml:space="preserve">parameter</ml:id>
										<ml:str xml:space="preserve">P</ml:str>
									</ml:apply>
									<ml:return>
										<ml:apply>
											<ml:pow/>
											<ml:parens>
												<ml:apply>
													<ml:minus/>
													<ml:real>1</ml:real>
													<ml:apply>
														<ml:mult/>
														<ml:apply>
															<ml:pow/>
															<ml:id xml:space="preserve">λ</ml:id>
															<ml:real>2</ml:real>
														</ml:apply>
														<ml:apply>
															<ml:div/>
															<ml:apply>
																<ml:minus/>
																<ml:id xml:space="preserve">k</ml:id>
																<ml:real>1</ml:real>
															</ml:apply>
															<ml:apply>
																<ml:plus/>
																<ml:id xml:space="preserve">k</ml:id>
																<ml:real>1</ml:real>
															</ml:apply>
														</ml:apply>
													</ml:apply>
												</ml:apply>
											</ml:parens>
											<ml:apply>
												<ml:div/>
												<ml:id xml:space="preserve">k</ml:id>
												<ml:apply>
													<ml:minus/>
													<ml:id xml:space="preserve">k</ml:id>
													<ml:real>1</ml:real>
												</ml:apply>
											</ml:apply>
										</ml:apply>
									</ml:return>
								</ml:ifThen>
								<ml:ifThen>
									<ml:apply>
										<ml:equal/>
										<ml:id xml:space="preserve">parameter</ml:id>
										<ml:str xml:space="preserve">ρ</ml:str>
									</ml:apply>
									<ml:return>
										<ml:apply>
											<ml:pow/>
											<ml:parens>
												<ml:apply>
													<ml:minus/>
													<ml:real>1</ml:real>
													<ml:apply>
														<ml:mult/>
														<ml:apply>
															<ml:pow/>
															<ml:id xml:space="preserve">λ</ml:id>
															<ml:real>2</ml:real>
														</ml:apply>
														<ml:apply>
															<ml:div/>
															<ml:apply>
																<ml:minus/>
																<ml:id xml:space="preserve">k</ml:id>
																<ml:real>1</ml:real>
															</ml:apply>
															<ml:apply>
																<ml:plus/>
																<ml:id xml:space="preserve">k</ml:id>
																<ml:real>1</ml:real>
															</ml:apply>
														</ml:apply>
													</ml:apply>
												</ml:apply>
											</ml:parens>
											<ml:apply>
												<ml:div/>
												<ml:real>1</ml:real>
												<ml:apply>
													<ml:minus/>
													<ml:id xml:space="preserve">k</ml:id>
													<ml:real>1</ml:real>
												</ml:apply>
											</ml:apply>
										</ml:apply>
									</ml:return>
								</ml:ifThen>
								<ml:ifThen>
									<ml:apply>
										<ml:equal/>
										<ml:id xml:space="preserve">parameter</ml:id>
										<ml:str xml:space="preserve">G</ml:str>
									</ml:apply>
									<ml:return>
										<ml:apply>
											<ml:mult/>
											<ml:apply>
												<ml:mult/>
												<ml:id xml:space="preserve">λ</ml:id>
												<ml:apply>
													<ml:pow/>
													<ml:parens>
														<ml:apply>
															<ml:div/>
															<ml:apply>
																<ml:plus/>
																<ml:id xml:space="preserve">k</ml:id>
																<ml:real>1</ml:real>
															</ml:apply>
															<ml:real>2</ml:real>
														</ml:apply>
													</ml:parens>
													<ml:apply>
														<ml:div/>
														<ml:real>1</ml:real>
														<ml:apply>
															<ml:minus/>
															<ml:id xml:space="preserve">k</ml:id>
															<ml:real>1</ml:real>
														</ml:apply>
													</ml:apply>
												</ml:apply>
											</ml:apply>
											<ml:apply>
												<ml:pow/>
												<ml:parens>
													<ml:apply>
														<ml:minus/>
														<ml:real>1</ml:real>
														<ml:apply>
															<ml:mult/>
															<ml:apply>
																<ml:pow/>
																<ml:id xml:space="preserve">λ</ml:id>
																<ml:real>2</ml:real>
															</ml:apply>
															<ml:apply>
																<ml:div/>
																<ml:apply>
																	<ml:minus/>
																	<ml:id xml:space="preserve">k</ml:id>
																	<ml:real>1</ml:real>
																</ml:apply>
																<ml:apply>
																	<ml:plus/>
																	<ml:id xml:space="preserve">k</ml:id>
																	<ml:real>1</ml:real>
																</ml:apply>
															</ml:apply>
														</ml:apply>
													</ml:apply>
												</ml:parens>
												<ml:apply>
													<ml:div/>
													<ml:real>1</ml:real>
													<ml:apply>
														<ml:minus/>
														<ml:id xml:space="preserve">k</ml:id>
														<ml:real>1</ml:real>
													</ml:apply>
												</ml:apply>
											</ml:apply>
										</ml:apply>
									</ml:return>
								</ml:ifThen>
								<ml:otherwise>
									<ml:return>
										<ml:id xml:space="preserve">NaN</ml:id>
									</ml:return>
								</ml:otherwise>
							</ml:program>
						</ml:define>
					</math>
				</region>
				<region region-id="509229" left="6" top="6084.75" width="72" height="14.25" align-x="20.25" align-y="6096" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Коэф. расхода:</p>
					</text>
				</region>
				<region region-id="509230" left="114" top="6057.75" width="113.25" height="50.25" align-x="144" align-y="6096" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="q">m</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">k</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:apply>
								<ml:sqrt/>
								<ml:apply>
									<ml:mult/>
									<ml:id xml:space="preserve">k</ml:id>
									<ml:apply>
										<ml:pow/>
										<ml:parens>
											<ml:apply>
												<ml:div/>
												<ml:real>2</ml:real>
												<ml:apply>
													<ml:plus/>
													<ml:id xml:space="preserve">k</ml:id>
													<ml:real>1</ml:real>
												</ml:apply>
											</ml:apply>
										</ml:parens>
										<ml:apply>
											<ml:div/>
											<ml:apply>
												<ml:plus/>
												<ml:id xml:space="preserve">k</ml:id>
												<ml:real>1</ml:real>
											</ml:apply>
											<ml:apply>
												<ml:minus/>
												<ml:id xml:space="preserve">k</ml:id>
												<ml:real>1</ml:real>
											</ml:apply>
										</ml:apply>
									</ml:apply>
								</ml:apply>
							</ml:apply>
						</ml:define>
						<resultFormat numeric-only="true">
							<decimal precision="4" show-trailing-zeros="false" radix="dec" complex-threshold="10" zero-threshold="15" imaginary-value="i"/>
							<matrix display-style="auto" expand-nested-arrays="false"/>
