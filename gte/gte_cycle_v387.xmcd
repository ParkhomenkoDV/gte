				<region region-id="530298" left="552" top="9590.25" width="454.5" height="67.5" align-x="680.25" align-y="9612" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="трениеИвентиляция">ξ</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">D</ml:id>
									<ml:id xml:space="preserve">h</ml:id>
									<ml:id xml:space="preserve">u</ml:id>
									<ml:id xml:space="preserve">ρ</ml:id>
									<ml:id xml:space="preserve">G</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:localDefine>
									<ml:id xml:space="preserve" subscript="трениеИвентиляция">N</ml:id>
									<ml:apply>
										<ml:mult/>
										<ml:apply>
											<ml:mult/>
											<ml:apply>
												<ml:mult/>
												<ml:apply>
													<ml:pow/>
													<ml:real>10</ml:real>
													<ml:real>3</ml:real>
												</ml:apply>
												<ml:parens>
													<ml:apply>
														<ml:plus/>
														<ml:apply>
															<ml:mult/>
															<ml:real>1.07</ml:real>
															<ml:apply>
																<ml:pow/>
																<ml:parens>
																	<ml:id xml:space="preserve">D</ml:id>
																</ml:parens>
																<ml:real>2</ml:real>
															</ml:apply>
														</ml:apply>
														<ml:apply>
															<ml:mult/>
															<ml:apply>
																<ml:mult/>
																<ml:apply>
																	<ml:mult/>
																	<ml:real>61</ml:real>
																	<ml:parens>
																		<ml:apply>
																			<ml:minus/>
																			<ml:real>1</ml:real>
																			<ml:real>1</ml:real>
																		</ml:apply>
																	</ml:parens>
																</ml:apply>
																<ml:id xml:space="preserve">D</ml:id>
															</ml:apply>
															<ml:id xml:space="preserve">h</ml:id>
														</ml:apply>
