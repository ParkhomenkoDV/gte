											<ml:real>8</ml:real>
										</ml:apply>
									</ml:apply>
									<ml:apply>
										<ml:minus/>
										<ml:apply>
											<ml:div/>
											<ml:real>2100</ml:real>
											<ml:id xml:space="preserve">Re</ml:id>
										</ml:apply>
