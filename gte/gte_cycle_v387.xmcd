									<ml:apply>
										<ml:greaterThan/>
										<ml:id xml:space="preserve" subscript="outlet">υ</ml:id>
										<ml:apply>
											<ml:div/>
											<ml:id xml:space="preserve">π</ml:id>
											<ml:real>2</ml:real>
										</ml:apply>
									</ml:apply>
									<ml:localDefine>
										<ml:id xml:space="preserve" subscript="outlet">υ</ml:id>
										<ml:apply>
											<ml:minus/>
											<ml:id xml:space="preserve">π</ml:id>
											<ml:id xml:space="preserve" subscript="outlet">υ</ml:id>
										</ml:apply>
									</ml:localDefine>
								</ml:ifThen>
								<ml:apply>
									<ml:id xml:space="preserve">atan</ml:id>
									<ml:apply>
										<ml:div/>
										<ml:apply>
											<ml:id xml:space="preserve">tan</ml:id>
											<ml:id xml:space="preserve" subscript="outlet">υ</ml:id>
										</ml:apply>
										<ml:apply>
											<ml:plus/>
											<ml:real>1</ml:real>
											<ml:apply>
												<ml:mult/>
												<ml:parens>
													<ml:apply>
														<ml:minus/>
														<ml:apply>
															<ml:div/>
															<ml:apply>
																<ml:id xml:space="preserve">tan</ml:id>
																<ml:id xml:space="preserve" subscript="outlet">υ</ml:id>
															</ml:apply>
															<ml:apply>
																<ml:id xml:space="preserve">tan</ml:id>
																<ml:id xml:space="preserve" subscript="inlet">υ</ml:id>
															</ml:apply>
														</ml:apply>
