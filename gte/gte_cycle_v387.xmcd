				<region region-id="509231" left="6" top="6132.75" width="96" height="14.25" align-x="21" align-y="6144" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Число Рейнольдса:</p>
					</text>
				</region>
				<region region-id="509232" left="114" top="6128.25" width="107.25" height="27.75" align-x="175.5" align-y="6144" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve">Re</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">v</ml:id>
									<ml:id xml:space="preserve">d</ml:id>
