										<ml:id xml:space="preserve">Jx0</ml:id>
										<ml:id xml:space="preserve">Jy0</ml:id>
									</ml:apply>
								</ml:localDefine>
								<ml:localDefine>
									<ml:id xml:space="preserve">Wp</ml:id>
									<ml:apply>
										<ml:div/>
										<ml:id xml:space="preserve">Jp</ml:id>
										<ml:apply>
											<ml:id xml:space="preserve">max</ml:id>
											<ml:sequence>
												<ml:apply>
													<ml:sqrt/>
													<ml:apply>
														<ml:plus/>
														<ml:apply>
															<ml:pow/>
															<ml:parens>
																<ml:apply>
																	<ml:minus/>
																	<ml:real>0</ml:real>
																	<ml:id xml:space="preserve">x0</ml:id>
																</ml:apply>
															</ml:parens>
															<ml:real>2</ml:real>
														</ml:apply>
														<ml:apply>
															<ml:pow/>
															<ml:parens>
																<ml:apply>
																	<ml:minus/>
																	<ml:real>0</ml:real>
																	<ml:id xml:space="preserve">y0</ml:id>
																</ml:apply>
															</ml:parens>
															<ml:real>2</ml:real>
														</ml:apply>
													</ml:apply>
												</ml:apply>
												<ml:apply>
													<ml:sqrt/>
													<ml:apply>
														<ml:plus/>
														<ml:apply>
															<ml:pow/>
															<ml:parens>
																<ml:apply>
																	<ml:minus/>
																	<ml:real>1</ml:real>
																	<ml:id xml:space="preserve">x0</ml:id>
																</ml:apply>
															</ml:parens>
															<ml:real>2</ml:real>
														</ml:apply>
														<ml:apply>
															<ml:pow/>
															<ml:parens>
																<ml:apply>
																	<ml:minus/>
																	<ml:real>0</ml:real>
																	<ml:id xml:space="preserve">y0</ml:id>
																</ml:apply>
