				<region region-id="522790" left="6" top="1056.75" width="120.75" height="14.25" align-x="46.5" align-y="1068" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Относ. профиль NACA:</p>
					</text>
				</region>
				<region region-id="522812" left="138" top="1059" width="412.5" height="559.5" align-x="220.5" align-y="1068" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve">NACA</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">f̅</ml:id>
									<ml:id xml:space="preserve" subscript="f">x̅</ml:id>
									<ml:id xml:space="preserve">c̅</ml:id>
									<ml:id xml:space="preserve">o</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:localDefine>
									<ml:matrix rows="1" cols="2">
										<ml:id xml:space="preserve" subscript="minU">i</ml:id>
										<ml:id xml:space="preserve" subscript="minL">i</ml:id>
									</ml:matrix>
									<ml:matrix rows="1" cols="2">
										<ml:id xml:space="preserve">ORIGIN</ml:id>
										<ml:id xml:space="preserve">ORIGIN</ml:id>
									</ml:matrix>
								</ml:localDefine>
								<ml:for>
									<ml:id xml:space="preserve">i</ml:id>
									<ml:range>
										<ml:real>1</ml:real>
										<ml:id xml:space="preserve" subscript="dis">N</ml:id>
									</ml:range>
									<ml:program>
										<ml:localDefine>
											<ml:apply>
												<ml:indexer/>
												<ml:id xml:space="preserve" subscript="i">β</ml:id>
												<ml:id xml:space="preserve">i</ml:id>
											</ml:apply>
											<ml:apply>
												<ml:plus/>
												<ml:real>0</ml:real>
												<ml:apply>
													<ml:mult/>
													<ml:parens>
														<ml:apply>
															<ml:minus/>
															<ml:id xml:space="preserve">i</ml:id>
															<ml:real>1</ml:real>
														</ml:apply>
													</ml:parens>
													<ml:apply>
														<ml:div/>
														<ml:id xml:space="preserve">π</ml:id>
														<ml:apply>
															<ml:mult/>
															<ml:real>2</ml:real>
															<ml:id xml:space="preserve" subscript="dis">N</ml:id>
														</ml:apply>
													</ml:apply>
												</ml:apply>
											</ml:apply>
										</ml:localDefine>
										<ml:localDefine>
											<ml:apply>
												<ml:indexer/>
												<ml:id xml:space="preserve" subscript="i">X</ml:id>
												<ml:id xml:space="preserve">i</ml:id>
											</ml:apply>
											<ml:apply>
												<ml:minus/>
												<ml:real>1</ml:real>
												<ml:apply>
													<ml:id xml:space="preserve">cos</ml:id>
													<ml:apply>
														<ml:indexer/>
														<ml:id xml:space="preserve" subscript="i">β</ml:id>
														<ml:id xml:space="preserve">i</ml:id>
													</ml:apply>
												</ml:apply>
											</ml:apply>
										</ml:localDefine>
										<ml:localDefine>
											<ml:apply>
												<ml:indexer/>
												<ml:id xml:space="preserve" subscript="f">Y</ml:id>
												<ml:id xml:space="preserve">i</ml:id>
											</ml:apply>
											<ml:apply>
												<ml:mult/>
												<ml:id xml:space="preserve">f̅</ml:id>
												<ml:program>
													<ml:ifThen>
														<ml:apply>
															<ml:lessThan/>
															<ml:apply>
																<ml:lessOrEqual/>
																<ml:real>0</ml:real>
																<ml:apply>
																	<ml:indexer/>
																	<ml:id xml:space="preserve" subscript="i">X</ml:id>
																	<ml:id xml:space="preserve">i</ml:id>
																</ml:apply>
															</ml:apply>
															<ml:id xml:space="preserve" subscript="f">x̅</ml:id>
														</ml:apply>
														<ml:apply>
															<ml:mult/>
															<ml:apply>
																<ml:pow/>
																<ml:id xml:space="preserve" subscript="f">x̅</ml:id>
																<ml:real>-2</ml:real>
															</ml:apply>
															<ml:parens>
																<ml:apply>
