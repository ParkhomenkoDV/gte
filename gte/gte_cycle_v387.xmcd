				<region region-id="530069" left="690" top="9378.75" width="156.75" height="14.25" align-x="714.75" align-y="9390" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Удельные потери в Л [1, с. 79]:</p>
					</text>
				</region>
				<region region-id="530070" left="858" top="9368.25" width="114" height="33.75" align-x="899.25" align-y="9390" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="Л">ξ</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">ξ</ml:id>
									<ml:id xml:space="preserve">υ</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:apply>
								<ml:div/>
								<ml:apply>
									<ml:mult/>
									<ml:parens>
										<ml:apply>
											<ml:minus/>
											<ml:apply>
												<ml:pow/>
												<ml:id xml:space="preserve">ξ</ml:id>
												<ml:real>-2</ml:real>
											</ml:apply>
											<ml:real>1</ml:real>
										</ml:apply>
									</ml:parens>
									<ml:apply>
										<ml:pow/>
										<ml:id xml:space="preserve">υ</ml:id>
										<ml:real>2</ml:real>
									</ml:apply>
								</ml:apply>
								<ml:real>2</ml:real>
							</ml:apply>
						</ml:define>
					</math>
				</region>
				<region region-id="530064" left="6" top="9387" width="487.5" height="121.5" align-x="93" align-y="9396" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="трение">ξ</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve" subscript="inlet">γ</ml:id>
									<ml:id xml:space="preserve" subscript="outlet">γ</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:localDefine>
									<ml:id xml:space="preserve">x</ml:id>
									<ml:program>
										<ml:ifThen>
											<ml:apply>
												<ml:lessOrEqual/>
												<ml:apply>
													<ml:plus/>
													<ml:id xml:space="preserve" subscript="inlet">γ</ml:id>
													<ml:id xml:space="preserve" subscript="outlet">γ</ml:id>
												</ml:apply>
												<ml:apply>
													<ml:mult style="auto-select"/>
													<ml:real>110</ml:real>
													<ml:id xml:space="preserve">°</ml:id>
												</ml:apply>
											</ml:apply>
											<ml:apply>
												<ml:plus/>
												<ml:id xml:space="preserve" subscript="inlet">γ</ml:id>
												<ml:id xml:space="preserve" subscript="outlet">γ</ml:id>
											</ml:apply>
										</ml:ifThen>
										<ml:otherwise>
											<ml:apply>
												<ml:mult style="auto-select"/>
												<ml:real>110</ml:real>
												<ml:id xml:space="preserve">°</ml:id>
											</ml:apply>
										</ml:otherwise>
									</ml:program>
								</ml:localDefine>
								<ml:localDefine>
									<ml:id xml:space="preserve">y</ml:id>
									<ml:program>
										<ml:ifThen>
											<ml:apply>
												<ml:lessOrEqual/>
												<ml:apply>
													<ml:div/>
													<ml:apply>
														<ml:id xml:space="preserve">sin</ml:id>
														<ml:id xml:space="preserve" subscript="inlet">γ</ml:id>
													</ml:apply>
													<ml:apply>
														<ml:id xml:space="preserve">sin</ml:id>
														<ml:id xml:space="preserve" subscript="outlet">γ</ml:id>
													</ml:apply>
												</ml:apply>
												<ml:real>1.7</ml:real>
