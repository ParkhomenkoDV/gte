				<region region-id="516277" left="192" top="6362.25" width="357" height="87.75" align-x="264" align-y="6384" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve">λ</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">substance</ml:id>
									<ml:id xml:space="preserve">T</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:ifThen>
									<ml:apply>
										<ml:equal/>
										<ml:id xml:space="preserve">substance</ml:id>
										<ml:str xml:space="preserve">воздух</ml:str>
									</ml:apply>
									<ml:apply>
										<ml:mult/>
										<ml:apply>
											<ml:mult/>
											<ml:real>244.2</ml:real>
											<ml:apply>
												<ml:pow/>
												<ml:real>10</ml:real>
												<ml:real>-4</ml:real>
											</ml:apply>
										</ml:apply>
										<ml:apply>
											<ml:pow/>
											<ml:parens>
												<ml:apply>
													<ml:div/>
													<ml:id xml:space="preserve">T</ml:id>
													<ml:real>273.15</ml:real>
												</ml:apply>
											</ml:parens>
											<ml:real>0.82</ml:real>
										</ml:apply>
									</ml:apply>
								</ml:ifThen>
								<ml:ifThen>
									<ml:apply>
										<ml:equal/>
										<ml:id xml:space="preserve">substance</ml:id>
										<ml:str xml:space="preserve">продукты сгорания</ml:str>
									</ml:apply>
									<ml:apply>
										<ml:mult/>
										<ml:apply>
											<ml:mult/>
											<ml:real>147</ml:real>
											<ml:apply>
												<ml:pow/>
												<ml:real>10</ml:real>
												<ml:real>-4</ml:real>
											</ml:apply>
										</ml:apply>
										<ml:apply>
											<ml:pow/>
											<ml:parens>
												<ml:apply>
													<ml:div/>
													<ml:id xml:space="preserve">T</ml:id>
													<ml:real>273.15</ml:real>
												</ml:apply>
											</ml:parens>
											<ml:real>1.23</ml:real>
										</ml:apply>
									</ml:apply>
								</ml:ifThen>
								<ml:otherwise>
									<ml:id xml:space="preserve">NaN</ml:id>
								</ml:otherwise>
							</ml:program>
						</ml:define>
					</math>
				</region>
				<region region-id="516270" left="6" top="6486.75" width="153.75" height="14.25" align-x="36" align-y="6498" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
