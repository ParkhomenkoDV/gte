														<ml:mult/>
														<ml:apply>
															<ml:mult/>
															<ml:id xml:space="preserve" subscript="add">g</ml:id>
															<ml:apply>
																<ml:id xml:space="preserve" subscript="воздух.ср">Cp</ml:id>
																<ml:sequence>
																	<ml:apply>
																		<ml:id xml:space="preserve" subscript="атм">P</ml:id>
																		<ml:real>0</ml:real>
																	</ml:apply>
																	<ml:id xml:space="preserve" subscript="add">P</ml:id>
																	<ml:apply>
																		<ml:id xml:space="preserve" subscript="атм">T</ml:id>
																		<ml:real>0</ml:real>
																	</ml:apply>
																	<ml:id xml:space="preserve" subscript="add">T</ml:id>
																</ml:sequence>
															</ml:apply>
														</ml:apply>
														<ml:id xml:space="preserve" subscript="add">T</ml:id>
													</ml:apply>
												</ml:apply>
												<ml:apply>
													<ml:plus split="true"/>
													<ml:apply>
														<ml:mult/>
														<ml:id xml:space="preserve">g</ml:id>
														<ml:apply>
															<ml:id xml:space="preserve" subscript="газ.ср">Cp</ml:id>
															<ml:sequence>
																<ml:apply>
																	<ml:id xml:space="preserve" subscript="атм">P</ml:id>
																	<ml:real>0</ml:real>
																</ml:apply>
																<ml:id xml:space="preserve">P</ml:id>
																<ml:apply>
																	<ml:id xml:space="preserve" subscript="атм">T</ml:id>
																	<ml:real>0</ml:real>
																</ml:apply>
																<ml:id xml:space="preserve" subscript="см">T</ml:id>
																<ml:id xml:space="preserve" subscript="ок1">α</ml:id>
																<ml:id xml:space="preserve" subscript="ок3">α</ml:id>
																<ml:id xml:space="preserve">Fuel</ml:id>
															</ml:sequence>
														</ml:apply>
													</ml:apply>
													<ml:apply>
														<ml:mult/>
														<ml:id xml:space="preserve" subscript="add">g</ml:id>
														<ml:apply>
															<ml:id xml:space="preserve" subscript="воздух.ср">Cp</ml:id>
															<ml:sequence>
																<ml:apply>
																	<ml:id xml:space="preserve" subscript="атм">P</ml:id>
																	<ml:real>0</ml:real>
																</ml:apply>
																<ml:id xml:space="preserve" subscript="add">P</ml:id>
																<ml:apply>
																	<ml:id xml:space="preserve" subscript="атм">T</ml:id>
																	<ml:real>0</ml:real>
																</ml:apply>
																<ml:id xml:space="preserve" subscript="см">T</ml:id>
															</ml:sequence>
														</ml:apply>
													</ml:apply>
												</ml:apply>
											</ml:apply>
										</ml:localDefine>
										<ml:ifThen>
											<ml:apply>
												<ml:lessOrEqual/>
												<ml:apply>
													<ml:absval/>
													<ml:apply>
														<ml:id xml:space="preserve">eps</ml:id>
														<ml:sequence>
															<ml:str xml:space="preserve">rel</ml:str>
															<ml:id xml:space="preserve" subscript="см">T</ml:id>
															<ml:id xml:space="preserve" subscript="см">T'</ml:id>
														</ml:sequence>
													</ml:apply>
												</ml:apply>
												<ml:id xml:space="preserve">epsilon</ml:id>
											</ml:apply>
											<ml:return>
												<ml:id xml:space="preserve" subscript="см">T'</ml:id>
											</ml:return>
										</ml:ifThen>
										<ml:localDefine>
											<ml:id xml:space="preserve" subscript="см">T</ml:id>
											<ml:id xml:space="preserve" subscript="см">T'</ml:id>
										</ml:localDefine>
									</ml:program>
								</ml:while>
							</ml:program>
						</ml:define>
					</math>
				</region>
				<region region-id="509243" left="6" top="7662" width="188.25" height="32.25" align-x="111" align-y="7680" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
