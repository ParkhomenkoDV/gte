				<region region-id="525059" left="6" top="7755" width="417" height="324" align-x="165.75" align-y="7764" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve">COMPRESSOR3</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">π*</ml:id>
									<ml:id xml:space="preserve">η*</ml:id>
									<ml:id xml:space="preserve" subscript="1">k</ml:id>
									<ml:id xml:space="preserve" subscript="1">P*</ml:id>
									<ml:id xml:space="preserve" subscript="1">T*</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:localDefine>
									<ml:id xml:space="preserve" subscript="3">P*</ml:id>
									<ml:apply>
										<ml:mult/>
										<ml:id xml:space="preserve" subscript="1">P*</ml:id>
										<ml:id xml:space="preserve">π*</ml:id>
									</ml:apply>
								</ml:localDefine>
								<ml:localDefine>
									<ml:id xml:space="preserve">iteration</ml:id>
									<ml:real>0</ml:real>
								</ml:localDefine>
								<ml:localDefine>
									<ml:id xml:space="preserve" subscript="3">T*</ml:id>
									<ml:id xml:space="preserve" subscript="1">T*</ml:id>
								</ml:localDefine>
								<ml:while>
									<ml:apply>
										<ml:greaterThan/>
										<ml:real>1</ml:real>
										<ml:real>0</ml:real>
									</ml:apply>
									<ml:program>
										<ml:localDefine>
											<ml:id xml:space="preserve">iteration</ml:id>
											<ml:apply>
												<ml:plus/>
												<ml:id xml:space="preserve">iteration</ml:id>
												<ml:real>1</ml:real>
