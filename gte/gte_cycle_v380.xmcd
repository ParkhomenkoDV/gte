													<ml:str xml:space="preserve">        iteration T = </ml:str>
													<ml:apply>
														<ml:id xml:space="preserve">num2str</ml:id>
														<ml:id xml:space="preserve">iteration</ml:id>
													</ml:apply>
												</ml:sequence>
											</ml:apply>
										</ml:apply>
										<ml:localDefine>
											<ml:id xml:space="preserve">R</ml:id>
											<ml:apply>
												<ml:id xml:space="preserve" subscript="газ.ср">R</ml:id>
												<ml:sequence>
													<ml:id xml:space="preserve" subscript="СА3">α</ml:id>
													<ml:id xml:space="preserve" subscript="РК3">α</ml:id>
													<ml:id xml:space="preserve">Fuel</ml:id>
												</ml:sequence>
											</ml:apply>
										</ml:localDefine>
										<ml:localDefine>
											<ml:id xml:space="preserve">Cp</ml:id>
											<ml:apply>
												<ml:id xml:space="preserve" subscript="газ.ср">Cp</ml:id>
												<ml:sequence>
													<ml:id xml:space="preserve" subscript="СА3">P*</ml:id>
													<ml:id xml:space="preserve" subscript="РК3">P*</ml:id>
													<ml:id xml:space="preserve" subscript="СА3">T*</ml:id>
													<ml:id xml:space="preserve" subscript="РК3">T*</ml:id>
													<ml:id xml:space="preserve" subscript="СА3">α</ml:id>
													<ml:id xml:space="preserve" subscript="РК3">α</ml:id>
													<ml:id xml:space="preserve">Fuel</ml:id>
												</ml:sequence>
											</ml:apply>
										</ml:localDefine>
										<ml:localDefine>
											<ml:id xml:space="preserve">k</ml:id>
											<ml:apply>
												<ml:id xml:space="preserve" subscript="ад">k</ml:id>
												<ml:sequence>
													<ml:id xml:space="preserve">Cp</ml:id>
													<ml:id xml:space="preserve">R</ml:id>
												</ml:sequence>
											</ml:apply>
										</ml:localDefine>
										<ml:localDefine>
											<ml:id xml:space="preserve">π*</ml:id>
											<ml:apply>
												<ml:pow/>
												<ml:parens>
													<ml:apply>
														<ml:minus/>
														<ml:real>1</ml:real>
														<ml:apply>
															<ml:div/>
															<ml:id xml:space="preserve">L</ml:id>
															<ml:apply>
																<ml:mult/>
																<ml:apply>
																	<ml:mult/>
																	<ml:id xml:space="preserve">Cp</ml:id>
																	<ml:id xml:space="preserve" subscript="СА3">T*</ml:id>
																</ml:apply>
																<ml:id xml:space="preserve">η*</ml:id>
															</ml:apply>
														</ml:apply>
													</ml:apply>
												</ml:parens>
												<ml:apply>
													<ml:div/>
													<ml:id xml:space="preserve">k</ml:id>
													<ml:apply>
														<ml:minus/>
														<ml:real>1</ml:real>
														<ml:id xml:space="preserve">k</ml:id>
													</ml:apply>
												</ml:apply>
											</ml:apply>
										</ml:localDefine>
										<ml:localDefine>
											<ml:id xml:space="preserve" subscript="РК3">P*</ml:id>
											<ml:apply>
												<ml:div/>
												<ml:id xml:space="preserve" subscript="СА3">P*</ml:id>
												<ml:id xml:space="preserve">π*</ml:id>
											</ml:apply>
										</ml:localDefine>
										<ml:localDefine>
											<ml:id xml:space="preserve" subscript="РК3">T*</ml:id>
											<ml:apply>
												<ml:minus/>
												<ml:id xml:space="preserve" subscript="СА3">T*</ml:id>
												<ml:apply>
													<ml:div/>
													<ml:id xml:space="preserve">L</ml:id>
													<ml:id xml:space="preserve">Cp</ml:id>
												</ml:apply>
											</ml:apply>
										</ml:localDefine>
										<ml:ifThen>
											<ml:apply>
												<ml:or/>
												<ml:apply>
													<ml:equal/>
													<ml:id xml:space="preserve">L</ml:id>
													<ml:real>0</ml:real>
												</ml:apply>
												<ml:apply>
													<ml:lessOrEqual/>
													<ml:apply>
														<ml:absval/>
														<ml:apply>
															<ml:id xml:space="preserve">eps</ml:id>
															<ml:sequence>
																<ml:str xml:space="preserve">rel</ml:str>
																<ml:id xml:space="preserve">L</ml:id>
																<ml:apply>
																	<ml:mult/>
																	<ml:apply>
																		<ml:id xml:space="preserve" subscript="газ.ср">Cp</ml:id>
																		<ml:sequence>
																			<ml:id xml:space="preserve" subscript="СА3">P*</ml:id>
																			<ml:id xml:space="preserve" subscript="РК3">P*</ml:id>
																			<ml:id xml:space="preserve" subscript="СА3">T*</ml:id>
																			<ml:id xml:space="preserve" subscript="РК3">T*</ml:id>
																			<ml:id xml:space="preserve" subscript="СА3">α</ml:id>
																			<ml:id xml:space="preserve" subscript="РК3">α</ml:id>
																			<ml:id xml:space="preserve">Fuel</ml:id>
																		</ml:sequence>
																	</ml:apply>
																	<ml:parens>
																		<ml:apply>
																			<ml:minus/>
																			<ml:id xml:space="preserve" subscript="СА3">T*</ml:id>
																			<ml:id xml:space="preserve" subscript="РК3">T*</ml:id>
																		</ml:apply>
																	</ml:parens>
																</ml:apply>
															</ml:sequence>
														</ml:apply>
													</ml:apply>
													<ml:id xml:space="preserve">epsilon</ml:id>
												</ml:apply>
											</ml:apply>
											<ml:break/>
										</ml:ifThen>
									</ml:program>
								</ml:while>
								<ml:localDefine>
									<ml:id xml:space="preserve" subscript="ок3">α</ml:id>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="смешение">α</ml:id>
										<ml:sequence>
											<ml:apply>
												<ml:minus/>
												<ml:id xml:space="preserve" subscript="1">g</ml:id>
												<ml:id xml:space="preserve" subscript="гор">g</ml:id>
											</ml:apply>
											<ml:id xml:space="preserve" subscript="охл">g</ml:id>
											<ml:id xml:space="preserve" subscript="гор">g</ml:id>
											<ml:id xml:space="preserve">Fuel</ml:id>
										</ml:sequence>
									</ml:apply>
								</ml:localDefine>
								<ml:localDefine>
									<ml:id xml:space="preserve" subscript="3">R</ml:id>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="газ">R</ml:id>
										<ml:sequence>
											<ml:id xml:space="preserve" subscript="ок3">α</ml:id>
											<ml:id xml:space="preserve">Fuel</ml:id>
										</ml:sequence>
									</ml:apply>
								</ml:localDefine>
								<ml:localDefine>
									<ml:id xml:space="preserve" subscript="3">P*</ml:id>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="смешение">P</ml:id>
										<ml:sequence>
											<ml:id xml:space="preserve" subscript="РК3">P*</ml:id>
											<ml:apply>
												<ml:plus/>
												<ml:id xml:space="preserve" subscript="1">g</ml:id>
												<ml:apply>
													<ml:mult/>
													<ml:id xml:space="preserve">χ</ml:id>
													<ml:id xml:space="preserve" subscript="охл">g</ml:id>
												</ml:apply>
											</ml:apply>
											<ml:id xml:space="preserve" subscript="охл">P*</ml:id>
											<ml:apply>
												<ml:mult/>
												<ml:parens>
													<ml:apply>
														<ml:minus/>
														<ml:real font="0">1</ml:real>
														<ml:id xml:space="preserve">χ</ml:id>
													</ml:apply>
												</ml:parens>
												<ml:id xml:space="preserve" subscript="охл">g</ml:id>
											</ml:apply>
										</ml:sequence>
									</ml:apply>
								</ml:localDefine>
								<ml:localDefine>
									<ml:id xml:space="preserve" subscript="3">T*</ml:id>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="смешение">T</ml:id>
										<ml:sequence>
											<ml:id xml:space="preserve" subscript="РК3">P*</ml:id>
											<ml:id xml:space="preserve" subscript="РК3">T*</ml:id>
											<ml:apply>
												<ml:plus/>
												<ml:id xml:space="preserve" subscript="1">g</ml:id>
												<ml:apply>
													<ml:mult/>
													<ml:id xml:space="preserve">χ</ml:id>
													<ml:id xml:space="preserve" subscript="охл">g</ml:id>
												</ml:apply>
											</ml:apply>
											<ml:id xml:space="preserve" subscript="РК3">α</ml:id>
											<ml:id xml:space="preserve" subscript="охл">P*</ml:id>
											<ml:id xml:space="preserve" subscript="охл">T*</ml:id>
											<ml:apply>
												<ml:mult/>
												<ml:parens>
													<ml:apply>
														<ml:minus/>
														<ml:real>1</ml:real>
														<ml:id xml:space="preserve">χ</ml:id>
													</ml:apply>
												</ml:parens>
												<ml:id xml:space="preserve" subscript="охл">g</ml:id>
											</ml:apply>
											<ml:id xml:space="preserve" subscript="ок3">α</ml:id>
											<ml:id xml:space="preserve">Fuel</ml:id>
										</ml:sequence>
									</ml:apply>
								</ml:localDefine>
								<ml:localDefine>
									<ml:id xml:space="preserve" subscript="3">Cp</ml:id>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="газ">Cp</ml:id>
										<ml:sequence>
											<ml:id xml:space="preserve" subscript="3">P*</ml:id>
											<ml:id xml:space="preserve" subscript="3">T*</ml:id>
											<ml:id xml:space="preserve" subscript="ок3">α</ml:id>
											<ml:id xml:space="preserve">Fuel</ml:id>
										</ml:sequence>
									</ml:apply>
								</ml:localDefine>
								<ml:localDefine>
									<ml:id xml:space="preserve" subscript="3">k</ml:id>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="ад">k</ml:id>
										<ml:sequence>
											<ml:id xml:space="preserve" subscript="3">Cp</ml:id>
											<ml:apply>
												<ml:id xml:space="preserve" subscript="газ">R</ml:id>
												<ml:sequence>
													<ml:id xml:space="preserve" subscript="ок3">α</ml:id>
													<ml:id xml:space="preserve">Fuel</ml:id>
												</ml:sequence>
											</ml:apply>
										</ml:sequence>
									</ml:apply>
								</ml:localDefine>
								<ml:apply>
									<ml:transpose/>
									<ml:matrix rows="1" cols="8">
										<ml:id xml:space="preserve">iteration</ml:id>
										<ml:id xml:space="preserve" subscript="ок3">α</ml:id>
										<ml:id xml:space="preserve" subscript="3">R</ml:id>
										<ml:id xml:space="preserve" subscript="3">T*</ml:id>
										<ml:id xml:space="preserve" subscript="3">P*</ml:id>
										<ml:id xml:space="preserve" subscript="3">Cp</ml:id>
										<ml:id xml:space="preserve" subscript="3">k</ml:id>
										<ml:id xml:space="preserve">π*</ml:id>
									</ml:matrix>
								</ml:apply>
							</ml:program>
						</ml:define>
					</math>
				</region>
				<region region-id="508352" left="0" top="9012" width="6000" height="6" align-x="0" align-y="9012" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<pageBreak/>
				</region>
				<region region-id="509250" left="6" top="9042.75" width="301.5" height="42.75" align-x="16.5" align-y="9054" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Фор-ла Тихонова относ. массового расхода на охлаждение</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">по максимальной и допустимой температуре, </p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">отнесенного к массовому расходу на выходе из КС:</p>
					</text>
				</region>
				<region region-id="509251" left="318" top="9048" width="355.5" height="36" align-x="396" align-y="9072" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="Тихонов">g</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve" subscript="г">T</ml:id>
									<ml:id xml:space="preserve" subscript="доп">T</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:apply>
								<ml:plus/>
								<ml:apply>
									<ml:plus/>
									<ml:apply>
										<ml:plus/>
										<ml:real>0.01</ml:real>
										<ml:apply>
											<ml:mult style="auto-select"/>
											<ml:real>0.09</ml:real>
											<ml:parens>
												<ml:apply>
													<ml:div/>
													<ml:apply>
														<ml:minus/>
														<ml:id xml:space="preserve" subscript="г">T</ml:id>
														<ml:id xml:space="preserve" subscript="доп">T</ml:id>
													</ml:apply>
													<ml:real>1000</ml:real>
												</ml:apply>
											</ml:parens>
										</ml:apply>
									</ml:apply>
									<ml:apply>
										<ml:mult style="auto-select"/>
										<ml:real>0.2</ml:real>
										<ml:apply>
											<ml:pow/>
											<ml:parens>
												<ml:apply>
													<ml:div/>
													<ml:apply>
														<ml:minus/>
														<ml:id xml:space="preserve" subscript="г">T</ml:id>
														<ml:id xml:space="preserve" subscript="доп">T</ml:id>
													</ml:apply>
													<ml:real>1000</ml:real>
												</ml:apply>
											</ml:parens>
											<ml:real>2</ml:real>
										</ml:apply>
									</ml:apply>
								</ml:apply>
								<ml:apply>
									<ml:mult/>
									<ml:real>0.16</ml:real>
									<ml:apply>
										<ml:pow/>
										<ml:parens>
											<ml:apply>
												<ml:div/>
												<ml:apply>
													<ml:minus/>
													<ml:id xml:space="preserve" subscript="г">T</ml:id>
													<ml:id xml:space="preserve" subscript="доп">T</ml:id>
												</ml:apply>
												<ml:real>1000</ml:real>
											</ml:apply>
										</ml:parens>
										<ml:real>3</ml:real>
									</ml:apply>
								</ml:apply>
							</ml:apply>
						</ml:define>
					</math>
				</region>
				<region region-id="509252" left="6" top="9132.75" width="301.5" height="42.75" align-x="16.5" align-y="9144" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Фор-ла ЦИАМ относ. массового расхода на охлаждение</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">по температурам перед КС, после КС и допустимой, </p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">отнесенного к массовому расходу на выходе из КС:</p>
					</text>
				</region>
				<region region-id="509253" left="318" top="9120.75" width="264" height="83.25" align-x="426.75" align-y="9156" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="ЦИАМ">g</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve" subscript="КС3">T</ml:id>
									<ml:id xml:space="preserve" subscript="доп">T</ml:id>
									<ml:id xml:space="preserve" subscript="КС1">T</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:localDefine>
									<ml:id xml:space="preserve">g</ml:id>
									<ml:apply>
										<ml:div/>
										<ml:apply>
											<ml:mult/>
											<ml:real>0.059</ml:real>
											<ml:parens>
												<ml:apply>
													<ml:div/>
													<ml:apply>
														<ml:minus/>
														<ml:id xml:space="preserve" subscript="КС3">T</ml:id>
														<ml:id xml:space="preserve" subscript="доп">T</ml:id>
													</ml:apply>
													<ml:apply>
														<ml:minus/>
														<ml:id xml:space="preserve" subscript="КС3">T</ml:id>
														<ml:id xml:space="preserve" subscript="КС1">T</ml:id>
													</ml:apply>
												</ml:apply>
											</ml:parens>
										</ml:apply>
										<ml:apply>
											<ml:minus/>
											<ml:real>1</ml:real>
											<ml:apply>
												<ml:mult/>
												<ml:real>1.42</ml:real>
												<ml:parens>
													<ml:apply>
														<ml:div/>
														<ml:apply>
															<ml:minus/>
															<ml:id xml:space="preserve" subscript="КС3">T</ml:id>
															<ml:id xml:space="preserve" subscript="доп">T</ml:id>
														</ml:apply>
														<ml:apply>
															<ml:minus/>
															<ml:id xml:space="preserve" subscript="КС3">T</ml:id>
															<ml:id xml:space="preserve" subscript="КС1">T</ml:id>
														</ml:apply>
													</ml:apply>
												</ml:parens>
											</ml:apply>
										</ml:apply>
									</ml:apply>
								</ml:localDefine>
								<ml:ifThen>
									<ml:apply>
										<ml:or/>
										<ml:apply>
											<ml:lessThan/>
											<ml:id xml:space="preserve">g</ml:id>
											<ml:real>0</ml:real>
										</ml:apply>
										<ml:apply>
											<ml:greaterThan/>
											<ml:id xml:space="preserve">g</ml:id>
											<ml:real>1</ml:real>
										</ml:apply>
									</ml:apply>
									<ml:localDefine>
										<ml:id xml:space="preserve">g</ml:id>
										<ml:id xml:space="preserve">NaN</ml:id>
									</ml:localDefine>
								</ml:ifThen>
							</ml:program>
						</ml:define>
					</math>
				</region>
				<region region-id="518952" left="0" top="9246" width="6000" height="6" align-x="0" align-y="9246" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<pageBreak/>
				</region>
				<region region-id="519177" left="6" top="9270.75" width="160.5" height="14.25" align-x="35.25" align-y="9282" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Постоянная Ларсона-Мюллера:</p>
					</text>
				</region>
				<region region-id="519178" left="174" top="9273" width="39.75" height="15" align-x="197.25" align-y="9282" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:globalDefine xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="ЛМ">C</ml:id>
							<ml:real>20</ml:real>
						</ml:globalDefine>
					</math>
