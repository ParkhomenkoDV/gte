				<region region-id="509228" left="6" top="2234.25" width="406.5" height="207.75" align-x="101.25" align-y="2250" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
