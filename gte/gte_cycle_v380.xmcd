					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="n">η*</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">node</ml:id>
									<ml:id xml:space="preserve">η*</ml:id>
									<ml:id xml:space="preserve">π*</ml:id>
									<ml:id xml:space="preserve">k</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:ifThen>
									<ml:apply>
										<ml:equal/>
										<ml:id xml:space="preserve">node</ml:id>
										<ml:str xml:space="preserve">сжатие</ml:str>
									</ml:apply>
									<ml:program>
										<ml:ifThen>
											<ml:apply>
												<ml:equal/>
												<ml:id xml:space="preserve">π*</ml:id>
												<ml:real>1</ml:real>
											</ml:apply>
											<ml:real>1</ml:real>
										</ml:ifThen>
										<ml:otherwise>
											<ml:apply>
												<ml:id xml:space="preserve">ln</ml:id>
												<ml:apply>
													<ml:plus/>
													<ml:apply>
														<ml:div/>
														<ml:apply>
															<ml:minus/>
															<ml:apply>
																<ml:pow/>
																<ml:id xml:space="preserve">π*</ml:id>
																<ml:apply>
																	<ml:div/>
																	<ml:apply>
																		<ml:minus/>
																		<ml:id xml:space="preserve">k</ml:id>
																		<ml:real>1</ml:real>
																	</ml:apply>
																	<ml:id xml:space="preserve">k</ml:id>
																</ml:apply>
															</ml:apply>
															<ml:real>1</ml:real>
														</ml:apply>
														<ml:id xml:space="preserve">η*</ml:id>
													</ml:apply>
													<ml:real>1</ml:real>
												</ml:apply>
											</ml:apply>
										</ml:otherwise>
									</ml:program>
								</ml:ifThen>
								<ml:ifThen>
									<ml:apply>
										<ml:equal/>
										<ml:id xml:space="preserve">node</ml:id>
										<ml:str xml:space="preserve">расширение</ml:str>
									</ml:apply>
									<ml:program>
										<ml:ifThen>
											<ml:apply>
												<ml:equal/>
												<ml:id xml:space="preserve">π*</ml:id>
												<ml:real>1</ml:real>
											</ml:apply>
											<ml:real>1</ml:real>
										</ml:ifThen>
										<ml:otherwise>
											<ml:apply>
												<ml:mult/>
												<ml:apply>
													<ml:neg/>
													<ml:apply>
														<ml:div/>
														<ml:id xml:space="preserve">k</ml:id>
														<ml:apply>
															<ml:minus/>
															<ml:id xml:space="preserve">k</ml:id>
															<ml:real>1</ml:real>
														</ml:apply>
													</ml:apply>
												</ml:apply>
												<ml:apply>
													<ml:div/>
													<ml:apply>
														<ml:id xml:space="preserve">ln</ml:id>
														<ml:apply>
															<ml:plus/>
															<ml:apply>
																<ml:mult/>
																<ml:id xml:space="preserve">η*</ml:id>
																<ml:parens>
																	<ml:apply>
																		<ml:minus/>
																		<ml:apply>
																			<ml:pow/>
																			<ml:id xml:space="preserve">π*</ml:id>
																			<ml:apply>
																				<ml:div/>
																				<ml:apply>
																					<ml:minus/>
																					<ml:real font="0">1</ml:real>
																					<ml:id xml:space="preserve">k</ml:id>
																				</ml:apply>
																				<ml:id xml:space="preserve">k</ml:id>
																			</ml:apply>
																		</ml:apply>
																		<ml:real>1</ml:real>
																	</ml:apply>
																</ml:parens>
															</ml:apply>
															<ml:real>1</ml:real>
														</ml:apply>
													</ml:apply>
													<ml:apply>
														<ml:id xml:space="preserve">ln</ml:id>
														<ml:id xml:space="preserve">π*</ml:id>
													</ml:apply>
												</ml:apply>
											</ml:apply>
										</ml:otherwise>
									</ml:program>
								</ml:ifThen>
								<ml:otherwise>
									<ml:id xml:space="preserve">NaN</ml:id>
								</ml:otherwise>
							</ml:program>
