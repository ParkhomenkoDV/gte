					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="смешение">T</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">P</ml:id>
									<ml:id xml:space="preserve">T</ml:id>
									<ml:id xml:space="preserve">g</ml:id>
									<ml:id xml:space="preserve" subscript="ок1">α</ml:id>
									<ml:id xml:space="preserve" subscript="add">P</ml:id>
									<ml:id xml:space="preserve" subscript="add">T</ml:id>
									<ml:id xml:space="preserve" subscript="add">g</ml:id>
									<ml:id xml:space="preserve" subscript="ок3">α</ml:id>
									<ml:id xml:space="preserve">Fuel</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:localDefine>
									<ml:id xml:space="preserve">iteration</ml:id>
									<ml:real>0</ml:real>
								</ml:localDefine>
								<ml:localDefine>
									<ml:id xml:space="preserve" subscript="см">T</ml:id>
									<ml:apply>
										<ml:div/>
										<ml:apply>
											<ml:plus/>
											<ml:apply>
												<ml:mult/>
												<ml:id xml:space="preserve">g</ml:id>
												<ml:id xml:space="preserve">T</ml:id>
											</ml:apply>
											<ml:apply>
												<ml:mult/>
												<ml:id xml:space="preserve" subscript="add">g</ml:id>
												<ml:id xml:space="preserve" subscript="add">T</ml:id>
											</ml:apply>
										</ml:apply>
										<ml:apply>
											<ml:plus/>
											<ml:id xml:space="preserve">g</ml:id>
											<ml:id xml:space="preserve" subscript="add">g</ml:id>
										</ml:apply>
									</ml:apply>
								</ml:localDefine>
								<ml:while>
									<ml:apply>
										<ml:greaterThan/>
										<ml:real>1</ml:real>
										<ml:real>0</ml:real>
									</ml:apply>
									<ml:program>
										<ml:localDefine>
											<ml:id xml:space="preserve">iteration</ml:id>
											<ml:apply>
												<ml:plus/>
												<ml:id xml:space="preserve">iteration</ml:id>
												<ml:real>1</ml:real>
											</ml:apply>
										</ml:localDefine>
										<ml:apply>
											<ml:id xml:space="preserve">trace</ml:id>
											<ml:apply>
												<ml:id xml:space="preserve">concat</ml:id>
												<ml:sequence>
													<ml:str xml:space="preserve">            iteration Tсм = </ml:str>
													<ml:apply>
														<ml:id xml:space="preserve">num2str</ml:id>
														<ml:id xml:space="preserve">iteration</ml:id>
													</ml:apply>
												</ml:sequence>
											</ml:apply>
										</ml:apply>
										<ml:localDefine>
											<ml:id xml:space="preserve" subscript="см">T'</ml:id>
