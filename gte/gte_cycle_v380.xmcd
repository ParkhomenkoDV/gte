									<ml:id xml:space="preserve">type</ml:id>
									<ml:id xml:space="preserve">x0</ml:id>
									<ml:id xml:space="preserve">x1</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:ifThen>
									<ml:apply>
										<ml:equal/>
										<ml:id xml:space="preserve">type</ml:id>
										<ml:str xml:space="preserve">rel</ml:str>
									</ml:apply>
									<ml:program>
										<ml:ifThen>
											<ml:apply>
												<ml:notEqual/>
												<ml:id xml:space="preserve">x0</ml:id>
												<ml:real>0</ml:real>
											</ml:apply>
											<ml:apply>
												<ml:div/>
												<ml:apply>
													<ml:minus/>
