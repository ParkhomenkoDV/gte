				<region region-id="517990" left="138" top="1028.25" width="249.75" height="27.75" align-x="234" align-y="1044" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
