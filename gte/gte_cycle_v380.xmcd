														<ml:id xml:space="preserve" subscript="1">T</ml:id>
														<ml:id xml:space="preserve" subscript="2">T</ml:id>
													</ml:bounds>
												</ml:apply>
											</ml:lambda>
											<ml:bounds>
												<ml:id xml:space="preserve" subscript="1">α</ml:id>
												<ml:id xml:space="preserve" subscript="2">α</ml:id>
											</ml:bounds>
										</ml:apply>
									</ml:apply>
								</ml:ifThen>
								<ml:otherwise>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="газ">Cp</ml:id>
										<ml:sequence>
											<ml:apply>
												<ml:id xml:space="preserve">mean</ml:id>
