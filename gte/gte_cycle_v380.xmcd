										<ml:mult/>
										<ml:apply>
											<ml:mult/>
											<ml:apply>
												<ml:div/>
												<ml:real>1</ml:real>
												<ml:apply>
													<ml:minus/>
													<ml:id xml:space="preserve" subscript="2">P</ml:id>
													<ml:id xml:space="preserve" subscript="1">P</ml:id>
												</ml:apply>
											</ml:apply>
											<ml:apply>
												<ml:div/>
												<ml:real>1</ml:real>
												<ml:apply>
													<ml:minus/>
													<ml:id xml:space="preserve" subscript="2">T</ml:id>
													<ml:id xml:space="preserve" subscript="1">T</ml:id>
												</ml:apply>
											</ml:apply>
										</ml:apply>
										<ml:apply>
											<ml:integral auto-algorithm="true"/>
											<ml:lambda>
												<ml:boundVars>
													<ml:id xml:space="preserve">P</ml:id>
