								<ml:ifThen>
									<ml:apply>
										<ml:equal/>
										<ml:id xml:space="preserve">parameter</ml:id>
										<ml:str xml:space="preserve">P</ml:str>
									</ml:apply>
									<ml:return>
										<ml:apply>
											<ml:pow/>
											<ml:parens>
												<ml:apply>
													<ml:minus/>
