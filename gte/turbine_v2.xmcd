			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="VP" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="center" list-style-type="inherit" tabs="inherit">Московский государственный технический университет им. Н. Э. Баумана</p>
			</text>
		</region>
		<region region-id="13471" left="66" top="230.25" width="342.75" height="20.25" align-x="96.75" align-y="246" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="VP" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="center" list-style-type="inherit" tabs="inherit">
					<f size="18">Расчёт турбины привода вентилятора.</f>
				</p>
			</text>
		</region>
		<region region-id="12527" left="312" top="408" width="191.25" height="75" align-x="335.25" align-y="420" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="VP" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Студент - Нягин П. В.</p>
				<p style="VP" margin-left="0" margin-right="0" text-indent="0" text-align="left" list-style-type="none" tabs="inherit">
					<br/>Группа - Э3 - 91</p>
				<p style="VP" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
					<br/>Преподаватель - Моляков В. Д.</p>
			</text>
		</region>
		<region region-id="12523" left="204" top="708" width="154.5" height="15" align-x="225.75" align-y="720" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="VP" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Москва, 2018г.</p>
			</text>
		</region>
		<region region-id="1369" left="6" top="738" width="491.25" height="51.75" align-x="28.5" align-y="750" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="VP" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Определим максимальную частоту вращения ротора турбины. Выберем рабочую частоту вращения ротора турбины, основные размеры<sp count="2"/>(<region region-id="37" left="335.25" top="753.75" width="16.5" height="21" align-x="342.75" align-y="765.75" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
						<math optimize="false" disable-calc="false">
							<ml:id xml:space="preserve" subscript="т" xmlns:ml="http://schemas.mathsoft.com/math30">D</ml:id>
						</math>
						<rendering item-idref="4"/>
					</region>, <region region-id="38" left="360" top="753.75" width="14.25" height="21" align-x="366" align-y="765.75" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
						<math optimize="false" disable-calc="false">
							<ml:id xml:space="preserve" subscript="т" xmlns:ml="http://schemas.mathsoft.com/math30">F</ml:id>
						</math>
						<rendering item-idref="5"/>
					</region>, <region region-id="40" left="382.5" top="753.75" width="9.75" height="21" align-x="386.25" align-y="765.75" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
						<math optimize="false" disable-calc="false">
							<ml:id xml:space="preserve" subscript="т" xmlns:ml="http://schemas.mathsoft.com/math30">l</ml:id>
						</math>
						<rendering item-idref="6"/>
					</region>/<region region-id="41" left="396.75" top="753.75" width="16.5" height="21" align-x="404.25" align-y="765.75" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
						<math optimize="false" disable-calc="false">
							<ml:id xml:space="preserve" subscript="т" xmlns:ml="http://schemas.mathsoft.com/math30">D</ml:id>
						</math>
						<rendering item-idref="7"/>
					</region>) и форму меридионального сечения проточной части</p>
			</text>
		</region>
		<region region-id="13245" left="126" top="804" width="168.75" height="15" align-x="135.75" align-y="816" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
