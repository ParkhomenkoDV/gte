			<rendering item-idref="325"/>
		</region>
		<region region-id="638" left="6" top="10614.75" width="475.5" height="42.75" align-x="12.75" align-y="10626" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Обычный" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">По графикам распределения температуры стенки внешней поверхности лопатки видно, что конвективное охлаждение не обеспечивает необходимую температуру лопатки. Следовательно необходимо использовать конвективно-пленочное охлаждение. </p>
			</text>
		</region>
		<region region-id="1354" left="696" top="10644.75" width="45" height="15.75" align-x="708.75" align-y="10656" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<math optimize="false" disable-calc="false">
				<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
					<ml:id xml:space="preserve">i</ml:id>
					<ml:range>
						<ml:real>0</ml:real>
						<ml:real>5</ml:real>
					</ml:range>
				</ml:define>
			</math>
			<rendering item-idref="326"/>
		</region>
		<region region-id="639" left="114" top="10662.75" width="160.5" height="14.25" align-x="130.5" align-y="10674" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Обычный" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Расчет пленочного охлаждения</p>
			</text>
		</region>
		<region region-id="640" left="6" top="10680.75" width="476.25" height="85.5" align-x="24" align-y="10692" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Обычный" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Эффект тепловой защиты поверхности лопатки при пленочном охлаждении достигается путем оттеснения горячего потока газа от стенки пленкой охлаждающего воздуха. Для расчета требуемого по условиям охлаждения параметра вдува необходимо знать локальную скорость газа в месте вдува пленки воздуха на поверхность лопатки. Скорость газа определялась на основании типичной кривой изменения приведенной скорости потока по обводу профиля.</p>
			</text>
		</region>
		<region region-id="5089" left="528" top="10682.25" width="106.5" height="120.75" align-x="580.5" align-y="10746" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<math optimize="false" disable-calc="false">
				<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
					<ml:id xml:space="preserve" subscript="охл.кан.с">T</ml:id>
					<ml:matrix rows="6" cols="1">
						<ml:real>757.4</ml:real>
						<ml:real>757.4</ml:real>
						<ml:real>757.4</ml:real>
						<ml:real>757.4</ml:real>
						<ml:real>757.4</ml:real>
						<ml:real>757.4</ml:real>
					</ml:matrix>
				</ml:define>
			</math>
			<rendering item-idref="327"/>
		</region>
		<region region-id="6249" left="876" top="10740.75" width="38.25" height="15.75" align-x="894" align-y="10752" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#ff8000" tag="">
