										<ml:apply>
											<ml:id xml:space="preserve" subscript="к4">θ</ml:id>
											<ml:id xml:space="preserve" subscript="кон.к4">x</ml:id>
										</ml:apply>
										<ml:parens>
											<ml:apply>
												<ml:minus/>
												<ml:apply>
													<ml:id xml:space="preserve" subscript="п.к3">T</ml:id>
