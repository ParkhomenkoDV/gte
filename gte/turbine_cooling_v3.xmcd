				<region region-id="1482" left="6" top="2340.75" width="374.25" height="18" align-x="38.25" align-y="2352" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
