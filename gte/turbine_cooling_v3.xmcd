				<region region-id="9350" left="6" top="2271" width="156.75" height="52.5" align-x="36.75" align-y="2280" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="к4">θ</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">x</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:ifThen>
									<ml:apply>
										<ml:lessOrEqual/>
										<ml:id xml:space="preserve">x</ml:id>
										<ml:id xml:space="preserve" subscript="н.к4">x</ml:id>
									</ml:apply>
									<ml:real>1</ml:real>
