									</ml:apply>
									<ml:id xml:space="preserve" subscript="охл.4">G</ml:id>
								</ml:apply>
							</ml:parens>
							<ml:real>45</ml:real>
						</ml:apply>
						<result xmlns="http://schemas.mathsoft.com/math30">
							<ml:real>6.8198684210526324</ml:real>
