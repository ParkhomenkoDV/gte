												<ml:div/>
												<ml:apply>
													<ml:minus/>
													<ml:id xml:space="preserve">x1</ml:id>
													<ml:id xml:space="preserve">x0</ml:id>
												</ml:apply>
												<ml:id xml:space="preserve">x0</ml:id>
											</ml:apply>
										</ml:ifThen>
										<ml:otherwise>
											<ml:id xml:space="preserve">∞</ml:id>
										</ml:otherwise>
									</ml:program>
								</ml:ifThen>
								<ml:ifThen>
									<ml:apply>
										<ml:equal/>
										<ml:id xml:space="preserve">type</ml:id>
										<ml:str xml:space="preserve">abs</ml:str>
									</ml:apply>
									<ml:apply>
										<ml:minus/>
										<ml:id xml:space="preserve">x1</ml:id>
										<ml:id xml:space="preserve">x0</ml:id>
									</ml:apply>
								</ml:ifThen>
							</ml:program>
						</ml:define>
					</math>
				</region>
				<region region-id="531054" left="624" top="366.75" width="139.5" height="14.25" align-x="638.25" align-y="378" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Точка пересечения прямых:</p>
					</text>
				</region>
				<region region-id="517989" left="6" top="414.75" width="120.75" height="14.25" align-x="20.25" align-y="426" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Целая часть от деления:</p>
					</text>
				</region>
				<region region-id="517990" left="138" top="410.25" width="249.75" height="27.75" align-x="234" align-y="426" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve">div</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">dividend</ml:id>
									<ml:id xml:space="preserve">divider</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:apply>
								<ml:div/>
								<ml:apply>
									<ml:minus/>
									<ml:id xml:space="preserve">dividend</ml:id>
									<ml:apply>
										<ml:id xml:space="preserve">mod</ml:id>
										<ml:sequence>
											<ml:id xml:space="preserve">dividend</ml:id>
											<ml:id xml:space="preserve">divider</ml:id>
										</ml:sequence>
									</ml:apply>
								</ml:apply>
								<ml:id xml:space="preserve">divider</ml:id>
							</ml:apply>
						</ml:define>
					</math>
				</region>
				<region region-id="531028" left="624" top="399.75" width="277.5" height="92.25" align-x="753" align-y="432" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve">COOR</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">A1</ml:id>
									<ml:id xml:space="preserve">B1</ml:id>
									<ml:id xml:space="preserve">C1</ml:id>
									<ml:id xml:space="preserve">A2</ml:id>
									<ml:id xml:space="preserve">B2</ml:id>
									<ml:id xml:space="preserve">C2</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:localDefine>
									<ml:matrix rows="2" cols="1">
										<ml:id xml:space="preserve">x</ml:id>
										<ml:id xml:space="preserve">y</ml:id>
									</ml:matrix>
									<ml:matrix rows="2" cols="1">
										<ml:apply>
											<ml:div/>
											<ml:apply>
												<ml:minus/>
												<ml:id xml:space="preserve">C1</ml:id>
												<ml:id xml:space="preserve">C2</ml:id>
											</ml:apply>
											<ml:apply>
												<ml:minus/>
												<ml:id xml:space="preserve">A2</ml:id>
												<ml:id xml:space="preserve">A1</ml:id>
											</ml:apply>
										</ml:apply>
										<ml:apply>
											<ml:div/>
											<ml:apply>
												<ml:minus/>
												<ml:apply>
													<ml:mult/>
													<ml:id xml:space="preserve">A2</ml:id>
													<ml:id xml:space="preserve">C1</ml:id>
												</ml:apply>
												<ml:apply>
													<ml:mult/>
													<ml:id xml:space="preserve">A1</ml:id>
													<ml:id xml:space="preserve">C2</ml:id>
												</ml:apply>
											</ml:apply>
											<ml:apply>
												<ml:minus/>
												<ml:id xml:space="preserve">A2</ml:id>
												<ml:id xml:space="preserve">A1</ml:id>
											</ml:apply>
										</ml:apply>
									</ml:matrix>
								</ml:localDefine>
								<ml:matrix rows="2" cols="1">
									<ml:id xml:space="preserve">x</ml:id>
									<ml:id xml:space="preserve">y</ml:id>
								</ml:matrix>
							</ml:program>
						</ml:define>
					</math>
				</region>
				<region region-id="518009" left="192" top="459" width="288" height="15" align-x="322.5" align-y="468" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="ПереносПоворот">Mx</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">x</ml:id>
									<ml:id xml:space="preserve">y</ml:id>
									<ml:id xml:space="preserve">xc</ml:id>
									<ml:id xml:space="preserve">yc</ml:id>
									<ml:id xml:space="preserve">α</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:apply>
								<ml:plus/>
								<ml:apply>
									<ml:mult/>
									<ml:parens>
										<ml:apply>
											<ml:minus/>
											<ml:id xml:space="preserve">x</ml:id>
											<ml:id xml:space="preserve">xc</ml:id>
										</ml:apply>
									</ml:parens>
									<ml:apply>
										<ml:id xml:space="preserve">cos</ml:id>
										<ml:id xml:space="preserve">α</ml:id>
									</ml:apply>
								</ml:apply>
								<ml:apply>
									<ml:mult/>
									<ml:parens>
										<ml:apply>
											<ml:minus/>
											<ml:id xml:space="preserve">y</ml:id>
											<ml:id xml:space="preserve">yc</ml:id>
										</ml:apply>
									</ml:parens>
									<ml:apply>
										<ml:id xml:space="preserve">sin</ml:id>
										<ml:id xml:space="preserve">α</ml:id>
									</ml:apply>
								</ml:apply>
							</ml:apply>
						</ml:define>
					</math>
				</region>
				<region region-id="518010" left="6" top="462.75" width="174" height="28.5" align-x="30" align-y="474" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Матрица переноса-поворота осей </p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">в точку против часовой стрелки:</p>
					</text>
				</region>
				<region region-id="518011" left="192" top="483" width="294.75" height="15" align-x="324" align-y="492" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="ПереносПоворот">My</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">x</ml:id>
									<ml:id xml:space="preserve">y</ml:id>
									<ml:id xml:space="preserve">xc</ml:id>
									<ml:id xml:space="preserve">yc</ml:id>
									<ml:id xml:space="preserve">α</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:apply>
								<ml:plus/>
								<ml:apply>
									<ml:mult/>
									<ml:apply>
										<ml:neg/>
										<ml:parens>
											<ml:apply>
												<ml:minus/>
												<ml:id xml:space="preserve">x</ml:id>
												<ml:id xml:space="preserve">xc</ml:id>
											</ml:apply>
										</ml:parens>
									</ml:apply>
									<ml:apply>
										<ml:id xml:space="preserve">sin</ml:id>
										<ml:id xml:space="preserve">α</ml:id>
									</ml:apply>
								</ml:apply>
								<ml:apply>
									<ml:mult/>
									<ml:parens>
										<ml:apply>
											<ml:minus/>
											<ml:id xml:space="preserve">y</ml:id>
											<ml:id xml:space="preserve">yc</ml:id>
										</ml:apply>
									</ml:parens>
									<ml:apply>
										<ml:id xml:space="preserve">cos</ml:id>
										<ml:id xml:space="preserve">α</ml:id>
									</ml:apply>
								</ml:apply>
							</ml:apply>
						</ml:define>
					</math>
				</region>
				<region region-id="518027" left="6" top="522.75" width="218.25" height="28.5" align-x="10.5" align-y="534" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Ф-я номера сечения по номеру ступени (i) </p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">и положению сечения в ступени (j):</p>
					</text>
				</region>
				<region region-id="518028" left="234" top="525" width="126" height="62.25" align-x="266.25" align-y="534" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve">st</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">i</ml:id>
									<ml:id xml:space="preserve">j</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:ifThen>
									<ml:apply>
										<ml:equal/>
										<ml:id xml:space="preserve">j</ml:id>
										<ml:real>1</ml:real>
									</ml:apply>
									<ml:apply>
										<ml:minus/>
										<ml:apply>
											<ml:mult/>
											<ml:real>2</ml:real>
											<ml:id xml:space="preserve">i</ml:id>
										</ml:apply>
										<ml:real>1</ml:real>
									</ml:apply>
								</ml:ifThen>
								<ml:ifThen>
									<ml:apply>
										<ml:equal/>
										<ml:id xml:space="preserve">j</ml:id>
										<ml:real>2</ml:real>
									</ml:apply>
									<ml:apply>
										<ml:mult/>
										<ml:real>2</ml:real>
										<ml:id xml:space="preserve">i</ml:id>
									</ml:apply>
								</ml:ifThen>
								<ml:ifThen>
									<ml:apply>
										<ml:equal/>
										<ml:id xml:space="preserve">j</ml:id>
										<ml:real>3</ml:real>
									</ml:apply>
									<ml:apply>
										<ml:plus/>
										<ml:apply>
											<ml:mult/>
											<ml:real>2</ml:real>
											<ml:id xml:space="preserve">i</ml:id>
										</ml:apply>
										<ml:real>1</ml:real>
									</ml:apply>
								</ml:ifThen>
								<ml:otherwise>
									<ml:id xml:space="preserve">NaN</ml:id>
								</ml:otherwise>
							</ml:program>
						</ml:define>
					</math>
				</region>
				<region region-id="531042" left="624" top="534.75" width="121.5" height="14.25" align-x="663" align-y="546" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Коэффициенты прямой:</p>
					</text>
				</region>
				<region region-id="518053" left="6" top="570.75" width="82.5" height="14.25" align-x="14.25" align-y="582" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Ф-я ср. сечения:</p>
					</text>
				</region>
				<region region-id="518054" left="96" top="573" width="86.25" height="15" align-x="130.5" align-y="582" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve">av</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve" subscript="r">N</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:apply>
								<ml:id xml:space="preserve">ceil</ml:id>
								<ml:apply>
									<ml:mult style="auto-select"/>
									<ml:real font="0">0.5</ml:real>
									<ml:id xml:space="preserve" subscript="r">N</ml:id>
								</ml:apply>
							</ml:apply>
						</ml:define>
					</math>
				</region>
				<region region-id="531036" left="624" top="571.5" width="241.5" height="125.25" align-x="723.75" align-y="612" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="ABC">LINE</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">x1</ml:id>
									<ml:id xml:space="preserve">y1</ml:id>
									<ml:id xml:space="preserve">x2</ml:id>
									<ml:id xml:space="preserve">y2</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:localDefine>
									<ml:matrix rows="3" cols="1">
										<ml:id xml:space="preserve">A</ml:id>
										<ml:id xml:space="preserve">B</ml:id>
										<ml:id xml:space="preserve">C</ml:id>
									</ml:matrix>
									<ml:matrix rows="3" cols="1">
										<ml:apply>
											<ml:div/>
											<ml:apply>
												<ml:minus/>
												<ml:id xml:space="preserve">y2</ml:id>
												<ml:id xml:space="preserve">y1</ml:id>
											</ml:apply>
											<ml:apply>
												<ml:minus/>
												<ml:id xml:space="preserve">x2</ml:id>
												<ml:id xml:space="preserve">x1</ml:id>
											</ml:apply>
										</ml:apply>
										<ml:real>-1</ml:real>
										<ml:apply>
											<ml:div/>
											<ml:apply>
												<ml:minus/>
												<ml:apply>
													<ml:mult/>
													<ml:id xml:space="preserve">x2</ml:id>
													<ml:id xml:space="preserve">y1</ml:id>
												</ml:apply>
												<ml:apply>
													<ml:mult/>
													<ml:id xml:space="preserve">x1</ml:id>
													<ml:id xml:space="preserve">y2</ml:id>
												</ml:apply>
											</ml:apply>
											<ml:apply>
												<ml:minus/>
												<ml:id xml:space="preserve">x2</ml:id>
												<ml:id xml:space="preserve">x1</ml:id>
											</ml:apply>
										</ml:apply>
									</ml:matrix>
								</ml:localDefine>
								<ml:matrix rows="3" cols="1">
									<ml:id xml:space="preserve">A</ml:id>
									<ml:id xml:space="preserve">B</ml:id>
									<ml:id xml:space="preserve">C</ml:id>
								</ml:matrix>
							</ml:program>
						</ml:define>
					</math>
				</region>
				<region region-id="529251" left="6" top="612.75" width="207.75" height="14.25" align-x="18" align-y="624" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Угол между проекциями скоростей [рад]:</p>
					</text>
				</region>
				<region region-id="529252" left="6" top="642" width="198" height="87" align-x="75.75" align-y="660" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve">triangle</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve" subscript="a">υ</ml:id>
									<ml:id xml:space="preserve" subscript="u">υ</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:ifThen>
									<ml:apply>
										<ml:greaterThan/>
										<ml:id xml:space="preserve" subscript="u">υ</ml:id>
										<ml:real>0</ml:real>
									</ml:apply>
									<ml:apply>
										<ml:id xml:space="preserve">atan</ml:id>
										<ml:apply>
											<ml:div/>
											<ml:id xml:space="preserve" subscript="a">υ</ml:id>
											<ml:id xml:space="preserve" subscript="u">υ</ml:id>
										</ml:apply>
									</ml:apply>
								</ml:ifThen>
								<ml:ifThen>
									<ml:apply>
										<ml:equal/>
										<ml:id xml:space="preserve" subscript="u">υ</ml:id>
										<ml:real>0</ml:real>
									</ml:apply>
									<ml:apply>
										<ml:mult/>
										<ml:real>0.5</ml:real>
										<ml:id xml:space="preserve">π</ml:id>
									</ml:apply>
								</ml:ifThen>
								<ml:ifThen>
									<ml:apply>
										<ml:lessThan/>
										<ml:id xml:space="preserve" subscript="u">υ</ml:id>
										<ml:real>0</ml:real>
									</ml:apply>
									<ml:apply>
										<ml:plus/>
										<ml:id xml:space="preserve">π</ml:id>
										<ml:apply>
											<ml:id xml:space="preserve">atan</ml:id>
											<ml:apply>
												<ml:div/>
												<ml:id xml:space="preserve" subscript="a">υ</ml:id>
												<ml:id xml:space="preserve" subscript="u">υ</ml:id>
											</ml:apply>
										</ml:apply>
									</ml:apply>
								</ml:ifThen>
							</ml:program>
						</ml:define>
					</math>
				</region>
				<region region-id="547523" left="324" top="684.75" width="105" height="14.25" align-x="332.25" align-y="696" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Ср. относ. радиус ():</p>
					</text>
				</region>
				<region region-id="547524" left="444" top="672.75" width="80.25" height="35.25" align-x="477" align-y="696" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
