													<ml:real>0.5</ml:real>
												</ml:sequence>
											</ml:apply>
										</ml:ifThen>
										<ml:ifThen>
											<ml:apply>
												<ml:equal/>
												<ml:id xml:space="preserve">type</ml:id>
												<ml:str xml:space="preserve">РК</ml:str>
											</ml:apply>
