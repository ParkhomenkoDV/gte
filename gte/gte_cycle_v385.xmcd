				<region region-id="530074" left="690" top="8526" width="285.75" height="32.25" align-x="796.5" align-y="8544" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
