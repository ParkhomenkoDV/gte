				<region region-id="530080" left="6" top="8769" width="288.75" height="65.25" align-x="94.5" align-y="8778" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
