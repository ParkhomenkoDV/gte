											<ml:real>0.0041</ml:real>
											<ml:apply>
												<ml:pow/>
												<ml:parens>
													<ml:apply>
														<ml:minus/>
														<ml:apply>
															<ml:div/>
															<ml:id xml:space="preserve" subscript="inlet">γ</ml:id>
