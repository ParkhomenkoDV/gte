					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Теплоемкость горючего (Дж/кг/К):</p>
					</text>
				</region>
				<region region-id="426232" left="6" top="6161.25" width="261.75" height="135" align-x="80.25" align-y="6170.25" show-border="true" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="гор">Cp</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">P</ml:id>
									<ml:id xml:space="preserve">T</ml:id>
									<ml:id xml:space="preserve">Fuel</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:ifThen>
									<ml:parens>
										<ml:apply>
											<ml:equal/>
											<ml:id xml:space="preserve">Fuel</ml:id>
											<ml:str xml:space="preserve">Керосин</ml:str>
										</ml:apply>
									</ml:parens>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="керосин">Cp</ml:id>
										<ml:id xml:space="preserve">T</ml:id>
									</ml:apply>
								</ml:ifThen>
								<ml:ifThen>
									<ml:parens>
										<ml:apply>
											<ml:equal/>
											<ml:id xml:space="preserve">Fuel</ml:id>
											<ml:str xml:space="preserve">Бензин</ml:str>
										</ml:apply>
									</ml:parens>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="бензин">Cp</ml:id>
										<ml:id xml:space="preserve">T</ml:id>
									</ml:apply>
								</ml:ifThen>
								<ml:ifThen>
									<ml:parens>
										<ml:apply>
											<ml:equal/>
											<ml:id xml:space="preserve">Fuel</ml:id>
											<ml:str xml:space="preserve">Дизель</ml:str>
										</ml:apply>
									</ml:parens>
									<ml:id xml:space="preserve">NaN</ml:id>
