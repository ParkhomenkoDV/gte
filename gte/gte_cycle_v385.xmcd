												<ml:apply>
													<ml:div/>
													<ml:id xml:space="preserve">λ</ml:id>
													<ml:id xml:space="preserve" subscript="опт">λ</ml:id>
												</ml:apply>
												<ml:real>0.3</ml:real>
											</ml:apply>
											<ml:real>0.3</ml:real>
										</ml:ifThen>
										<ml:ifThen>
											<ml:apply>
												<ml:lessOrEqual/>
												<ml:apply>
													<ml:lessOrEqual/>
													<ml:real>0.3</ml:real>
													<ml:apply>
														<ml:div/>
														<ml:id xml:space="preserve">λ</ml:id>
														<ml:id xml:space="preserve" subscript="опт">λ</ml:id>
													</ml:apply>
												</ml:apply>
												<ml:real>1.35</ml:real>
											</ml:apply>
											<ml:apply>
												<ml:div/>
												<ml:id xml:space="preserve">λ</ml:id>
												<ml:id xml:space="preserve" subscript="опт">λ</ml:id>
											</ml:apply>
										</ml:ifThen>
										<ml:ifThen>
											<ml:apply>
												<ml:lessThan/>
												<ml:real>1.35</ml:real>
												<ml:apply>
													<ml:div/>
													<ml:id xml:space="preserve">λ</ml:id>
													<ml:id xml:space="preserve" subscript="опт">λ</ml:id>
												</ml:apply>
											</ml:apply>
