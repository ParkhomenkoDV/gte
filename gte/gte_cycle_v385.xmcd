				<region region-id="546030" left="0" top="9864" width="6000" height="6" align-x="0" align-y="9864" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<pageBreak/>
				</region>
				<region region-id="546023" left="6" top="9900.75" width="90.75" height="14.25" align-x="30" align-y="9912" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Параметр пленки:</p>
					</text>
				</region>
				<region region-id="546024" left="108" top="9896.25" width="378.75" height="30" align-x="278.25" align-y="9912" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="пленка">A</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">x</ml:id>
									<ml:id xml:space="preserve" subscript="щель.экв">d</ml:id>
									<ml:id xml:space="preserve" subscript="экв">Re</ml:id>
									<ml:id xml:space="preserve" subscript="вдув">m</ml:id>
									<ml:id xml:space="preserve" subscript="фактор">T</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:apply>
								<ml:mult/>
								<ml:apply>
									<ml:mult/>
									<ml:apply>
										<ml:div/>
										<ml:id xml:space="preserve">x</ml:id>
										<ml:id xml:space="preserve" subscript="щель.экв">d</ml:id>
									</ml:apply>
									<ml:apply>
										<ml:mult/>
										<ml:apply>
											<ml:pow/>
											<ml:id xml:space="preserve" subscript="экв">Re</ml:id>
											<ml:real>-0.25</ml:real>
										</ml:apply>
										<ml:apply>
											<ml:pow/>
											<ml:id xml:space="preserve" subscript="вдув">m</ml:id>
											<ml:real>-1.3</ml:real>
										</ml:apply>
									</ml:apply>
								</ml:apply>
								<ml:apply>
									<ml:pow/>
									<ml:id xml:space="preserve" subscript="фактор">T</ml:id>
									<ml:real>-1.25</ml:real>
								</ml:apply>
							</ml:apply>
						</ml:define>
					</math>
				</region>
				<region region-id="546025" left="6" top="9948.75" width="180.75" height="14.25" align-x="38.25" align-y="9960" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<f size="12">Эффективность пленочного охл. ():</f>
						</p>
					</text>
				</region>
				<region region-id="546026" left="192" top="9951" width="179.25" height="87.75" align-x="243.75" align-y="9960" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="пленка">Θ</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">A</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:ifThen>
									<ml:apply>
										<ml:lessOrEqual/>
										<ml:id xml:space="preserve">A</ml:id>
										<ml:real>3</ml:real>
									</ml:apply>
									<ml:real>1</ml:real>
								</ml:ifThen>
								<ml:ifThen>
									<ml:apply>
										<ml:lessThan/>
										<ml:apply>
											<ml:lessThan/>
											<ml:real>3</ml:real>
											<ml:id xml:space="preserve">A</ml:id>
										</ml:apply>
										<ml:real>11</ml:real>
									</ml:apply>
									<ml:apply>
										<ml:pow/>
										<ml:parens>
											<ml:apply>
												<ml:div/>
												<ml:id xml:space="preserve">A</ml:id>
												<ml:real>3</ml:real>
											</ml:apply>
										</ml:parens>
										<ml:real>-0.285</ml:real>
									</ml:apply>
								</ml:ifThen>
								<ml:otherwise>
									<ml:apply>
										<ml:pow/>
										<ml:parens>
											<ml:apply>
												<ml:div/>
												<ml:id xml:space="preserve">A</ml:id>
												<ml:real>7.43</ml:real>
											</ml:apply>
										</ml:parens>
										<ml:real>-0.95</ml:real>
									</ml:apply>
								</ml:otherwise>
							</ml:program>
						</ml:define>
					</math>
				</region>
				<region region-id="546027" left="6" top="10074.75" width="168" height="14.25" align-x="20.25" align-y="10086" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Коэф. угла выдува охл. потока ():</p>
					</text>
				</region>
				<region region-id="546028" left="186" top="10077" width="258" height="44.25" align-x="216" align-y="10086" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="α">k</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">α</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:ifThen>
									<ml:apply>
										<ml:lessOrEqual/>
										<ml:id xml:space="preserve">α</ml:id>
										<ml:apply>
											<ml:mult/>
											<ml:real>30</ml:real>
											<ml:id xml:space="preserve">deg</ml:id>
										</ml:apply>
									</ml:apply>
									<ml:real>1</ml:real>
								</ml:ifThen>
								<ml:otherwise>
									<ml:apply>
										<ml:minus/>
										<ml:real>1</ml:real>
										<ml:apply>
											<ml:mult/>
											<ml:parens>
												<ml:apply>
													<ml:minus/>
													<ml:apply>
														<ml:div/>
														<ml:id xml:space="preserve">α</ml:id>
														<ml:id xml:space="preserve">deg</ml:id>
													</ml:apply>
													<ml:real>30</ml:real>
												</ml:apply>
											</ml:parens>
											<ml:apply>
												<ml:div/>
												<ml:apply>
													<ml:minus/>
													<ml:real>1</ml:real>
													<ml:apply>
														<ml:id xml:space="preserve">mean</ml:id>
														<ml:sequence>
															<ml:real>0.55</ml:real>
															<ml:real>0.73</ml:real>
														</ml:sequence>
													</ml:apply>
												</ml:apply>
												<ml:real>60</ml:real>
											</ml:apply>
										</ml:apply>
									</ml:apply>
								</ml:otherwise>
							</ml:program>
						</ml:define>
					</math>
				</region>
			</area>
			<rendering item-idref="62"/>
		</region>
