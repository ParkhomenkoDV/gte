				<region region-id="529364" left="6" top="1614" width="382.5" height="36" align-x="105.75" align-y="1638" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
