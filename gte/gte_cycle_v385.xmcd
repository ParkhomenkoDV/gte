										<ml:apply>
											<ml:plus/>
											<ml:apply>
												<ml:minus/>
												<ml:apply>
													<ml:mult/>
													<ml:real>0.005</ml:real>
													<ml:apply>
														<ml:pow/>
														<ml:id xml:space="preserve" subscript="2(b/t)=1">β</ml:id>
														<ml:real font="0">2</ml:real>
													</ml:apply>
												</ml:apply>
												<ml:apply>
													<ml:mult/>
													<ml:real>0.05</ml:real>
													<ml:id xml:space="preserve" subscript="2(b/t)=1">β</ml:id>
												</ml:apply>
											</ml:apply>
