										<ml:id xml:space="preserve" subscript="газ">Cp</ml:id>
										<ml:sequence>
											<ml:id xml:space="preserve" subscript="3">P*</ml:id>
											<ml:id xml:space="preserve" subscript="3">T*</ml:id>
											<ml:id xml:space="preserve" subscript="ок3">α</ml:id>
											<ml:id xml:space="preserve">Fuel</ml:id>
										</ml:sequence>
									</ml:apply>
								</ml:localDefine>
								<ml:localDefine>
									<ml:id xml:space="preserve" subscript="3">k</ml:id>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="ад">k</ml:id>
										<ml:sequence>
											<ml:id xml:space="preserve" subscript="3">Cp</ml:id>
											<ml:apply>
												<ml:id xml:space="preserve" subscript="газ">R</ml:id>
												<ml:sequence>
													<ml:id xml:space="preserve" subscript="ок3">α</ml:id>
													<ml:id xml:space="preserve">Fuel</ml:id>
												</ml:sequence>
											</ml:apply>
										</ml:sequence>
									</ml:apply>
								</ml:localDefine>
								<ml:apply>
									<ml:transpose/>
									<ml:matrix rows="1" cols="8">
										<ml:id xml:space="preserve">iteration</ml:id>
										<ml:id xml:space="preserve" subscript="ок3">α</ml:id>
										<ml:id xml:space="preserve" subscript="3">R</ml:id>
										<ml:id xml:space="preserve" subscript="3">T*</ml:id>
										<ml:id xml:space="preserve" subscript="3">P*</ml:id>
										<ml:id xml:space="preserve" subscript="3">Cp</ml:id>
										<ml:id xml:space="preserve" subscript="3">k</ml:id>
										<ml:id xml:space="preserve">π*</ml:id>
									</ml:matrix>
								</ml:apply>
							</ml:program>
						</ml:define>
					</math>
				</region>
				<region region-id="508352" left="0" top="7656" width="6000" height="6" align-x="0" align-y="7656" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<pageBreak/>
				</region>
				<region region-id="509250" left="6" top="7686.75" width="301.5" height="42.75" align-x="16.5" align-y="7698" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Фор-ла Тихонова относ. массового расхода на охлаждение</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">по максимальной и допустимой температуре, </p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">отнесенного к массовому расходу на выходе из КС:</p>
					</text>
				</region>
				<region region-id="509251" left="318" top="7692" width="384.75" height="85.5" align-x="396" align-y="7716" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="Тихонов">g</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve" subscript="г">T</ml:id>
									<ml:id xml:space="preserve" subscript="доп">T</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:localDefine>
									<ml:id xml:space="preserve">g</ml:id>
									<ml:apply>
										<ml:plus/>
										<ml:apply>
											<ml:plus/>
											<ml:apply>
												<ml:plus/>
												<ml:real>0.01</ml:real>
												<ml:apply>
													<ml:mult style="auto-select"/>
													<ml:real>0.09</ml:real>
													<ml:parens>
														<ml:apply>
															<ml:div/>
															<ml:apply>
																<ml:minus/>
																<ml:id xml:space="preserve" subscript="г">T</ml:id>
																<ml:id xml:space="preserve" subscript="доп">T</ml:id>
															</ml:apply>
															<ml:real>1000</ml:real>
														</ml:apply>
													</ml:parens>
												</ml:apply>
											</ml:apply>
											<ml:apply>
												<ml:mult style="auto-select"/>
												<ml:real>0.2</ml:real>
												<ml:apply>
													<ml:pow/>
													<ml:parens>
														<ml:apply>
															<ml:div/>
															<ml:apply>
																<ml:minus/>
																<ml:id xml:space="preserve" subscript="г">T</ml:id>
																<ml:id xml:space="preserve" subscript="доп">T</ml:id>
															</ml:apply>
															<ml:real>1000</ml:real>
														</ml:apply>
													</ml:parens>
													<ml:real>2</ml:real>
												</ml:apply>
											</ml:apply>
										</ml:apply>
										<ml:apply>
											<ml:mult/>
											<ml:real>0.16</ml:real>
											<ml:apply>
												<ml:pow/>
												<ml:parens>
													<ml:apply>
														<ml:div/>
														<ml:apply>
															<ml:minus/>
															<ml:id xml:space="preserve" subscript="г">T</ml:id>
															<ml:id xml:space="preserve" subscript="доп">T</ml:id>
														</ml:apply>
														<ml:real>1000</ml:real>
													</ml:apply>
												</ml:parens>
												<ml:real>3</ml:real>
											</ml:apply>
										</ml:apply>
									</ml:apply>
								</ml:localDefine>
								<ml:ifThen>
									<ml:apply>
										<ml:lessThan/>
										<ml:id xml:space="preserve">g</ml:id>
										<ml:real>0</ml:real>
									</ml:apply>
									<ml:localDefine>
										<ml:id xml:space="preserve">g</ml:id>
										<ml:real>0</ml:real>
									</ml:localDefine>
								</ml:ifThen>
								<ml:ifThen>
									<ml:apply>
										<ml:greaterThan/>
										<ml:id xml:space="preserve">g</ml:id>
										<ml:real>1</ml:real>
									</ml:apply>
									<ml:localDefine>
										<ml:id xml:space="preserve">g</ml:id>
										<ml:id xml:space="preserve">NaN</ml:id>
									</ml:localDefine>
								</ml:ifThen>
								<ml:id xml:space="preserve">g</ml:id>
							</ml:program>
						</ml:define>
					</math>
				</region>
				<region region-id="530184" left="6" top="7806.75" width="301.5" height="42.75" align-x="16.5" align-y="7818" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Фор-ла ЦИАМ относ. массового расхода на охлаждение</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">по температурам перед КС, после КС и допустимой, </p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">отнесенного к массовому расходу на выходе из КС:</p>
					</text>
				</region>
				<region region-id="530185" left="318" top="7812" width="295.5" height="81.75" align-x="426.75" align-y="7830" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="ЦИАМ">g</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve" subscript="КС3">T</ml:id>
									<ml:id xml:space="preserve" subscript="доп">T</ml:id>
									<ml:id xml:space="preserve" subscript="КС1">T</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:localDefine>
									<ml:id xml:space="preserve">g</ml:id>
									<ml:apply>
										<ml:div/>
										<ml:apply>
											<ml:mult/>
											<ml:real>0.059</ml:real>
											<ml:apply>
												<ml:id xml:space="preserve" subscript="глубина">θ</ml:id>
												<ml:sequence>
													<ml:id xml:space="preserve" subscript="КС3">T</ml:id>
													<ml:id xml:space="preserve" subscript="КС1">T</ml:id>
													<ml:id xml:space="preserve" subscript="доп">T</ml:id>
												</ml:sequence>
											</ml:apply>
										</ml:apply>
										<ml:apply>
											<ml:minus/>
											<ml:real>1</ml:real>
											<ml:apply>
												<ml:mult/>
												<ml:real>1.42</ml:real>
												<ml:apply>
													<ml:id xml:space="preserve" subscript="глубина">θ</ml:id>
													<ml:sequence>
														<ml:id xml:space="preserve" subscript="КС3">T</ml:id>
														<ml:id xml:space="preserve" subscript="КС1">T</ml:id>
														<ml:id xml:space="preserve" subscript="доп">T</ml:id>
													</ml:sequence>
												</ml:apply>
											</ml:apply>
										</ml:apply>
									</ml:apply>
								</ml:localDefine>
								<ml:ifThen>
									<ml:apply>
										<ml:lessThan/>
										<ml:id xml:space="preserve">g</ml:id>
										<ml:real>0</ml:real>
									</ml:apply>
									<ml:localDefine>
										<ml:id xml:space="preserve">g</ml:id>
										<ml:real>0</ml:real>
									</ml:localDefine>
								</ml:ifThen>
								<ml:ifThen>
									<ml:apply>
										<ml:greaterThan/>
										<ml:id xml:space="preserve">g</ml:id>
										<ml:real>1</ml:real>
									</ml:apply>
									<ml:localDefine>
										<ml:id xml:space="preserve">g</ml:id>
										<ml:id xml:space="preserve">NaN</ml:id>
									</ml:localDefine>
								</ml:ifThen>
								<ml:id xml:space="preserve">g</ml:id>
							</ml:program>
						</ml:define>
					</math>
				</region>
				<region region-id="530209" left="6" top="7926" width="823.5" height="372" align-x="6" align-y="7926" show-border="true" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
