									<ml:id xml:space="preserve" subscript="inlet">γ</ml:id>
									<ml:id xml:space="preserve" subscript="outlet">γ</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:apply>
								<ml:mult/>
								<ml:parens>
									<ml:apply>
										<ml:minus/>
										<ml:apply>
											<ml:minus/>
