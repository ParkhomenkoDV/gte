												<ml:id xml:space="preserve">mean</ml:id>
												<ml:sequence>
													<ml:real>0.4</ml:real>
													<ml:real>0.55</ml:real>
												</ml:sequence>
											</ml:apply>
										</ml:ifThen>
									</ml:program>
