				<region region-id="532927" left="6" top="1712.25" width="276" height="112.5" align-x="119.25" align-y="1728" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="installation">υ</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">k</ml:id>
									<ml:id xml:space="preserve" subscript="inlet">υ</ml:id>
									<ml:id xml:space="preserve" subscript="outlet">υ</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:ifThen>
									<ml:apply>
										<ml:greaterThan/>
										<ml:id xml:space="preserve" subscript="inlet">υ</ml:id>
										<ml:apply>
											<ml:div/>
											<ml:id xml:space="preserve">π</ml:id>
											<ml:real>2</ml:real>
										</ml:apply>
									</ml:apply>
									<ml:localDefine>
										<ml:id xml:space="preserve" subscript="inlet">υ</ml:id>
										<ml:apply>
											<ml:minus/>
											<ml:id xml:space="preserve">π</ml:id>
											<ml:id xml:space="preserve" subscript="inlet">υ</ml:id>
										</ml:apply>
									</ml:localDefine>
								</ml:ifThen>
								<ml:ifThen>
									<ml:apply>
										<ml:greaterThan/>
										<ml:id xml:space="preserve" subscript="outlet">υ</ml:id>
										<ml:apply>
											<ml:div/>
											<ml:id xml:space="preserve">π</ml:id>
											<ml:real>2</ml:real>
										</ml:apply>
									</ml:apply>
									<ml:localDefine>
										<ml:id xml:space="preserve" subscript="outlet">υ</ml:id>
										<ml:apply>
											<ml:minus/>
											<ml:id xml:space="preserve">π</ml:id>
											<ml:id xml:space="preserve" subscript="outlet">υ</ml:id>
										</ml:apply>
									</ml:localDefine>
								</ml:ifThen>
								<ml:apply>
									<ml:id xml:space="preserve">atan</ml:id>
									<ml:apply>
										<ml:div/>
										<ml:apply>
											<ml:id xml:space="preserve">tan</ml:id>
											<ml:id xml:space="preserve" subscript="outlet">υ</ml:id>
										</ml:apply>
										<ml:apply>
											<ml:plus/>
											<ml:real>1</ml:real>
											<ml:apply>
												<ml:mult/>
												<ml:parens>
													<ml:apply>
														<ml:minus/>
														<ml:apply>
															<ml:div/>
															<ml:apply>
																<ml:id xml:space="preserve">tan</ml:id>
																<ml:id xml:space="preserve" subscript="outlet">υ</ml:id>
															</ml:apply>
															<ml:apply>
																<ml:id xml:space="preserve">tan</ml:id>
																<ml:id xml:space="preserve" subscript="inlet">υ</ml:id>
															</ml:apply>
														</ml:apply>
														<ml:real>1</ml:real>
													</ml:apply>
												</ml:parens>
												<ml:id xml:space="preserve">k</ml:id>
											</ml:apply>
										</ml:apply>
									</ml:apply>
								</ml:apply>
							</ml:program>
						</ml:define>
					</math>
				</region>
				<region region-id="529365" left="6" top="1872.75" width="313.5" height="14.25" align-x="42" align-y="1884" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Оптимальный относительный шаг в решетке () [1, с.183-184]:</p>
					</text>
				</region>
				<region region-id="529366" left="6" top="1905" width="609" height="105" align-x="147.75" align-y="1914" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="опт">t̅</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">type</ml:id>
									<ml:id xml:space="preserve">cool</ml:id>
									<ml:id xml:space="preserve" subscript="inlet">γ</ml:id>
									<ml:id xml:space="preserve" subscript="outlet">γ</ml:id>
									<ml:id xml:space="preserve" subscript="max">c̅</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:localDefine>
									<ml:id xml:space="preserve" subscript="max">c̅</ml:id>
									<ml:program>
										<ml:ifThen>
											<ml:apply>
												<ml:equal/>
												<ml:id xml:space="preserve" subscript="max">c̅</ml:id>
												<ml:real>0</ml:real>
											</ml:apply>
											<ml:localDefine>
												<ml:id xml:space="preserve" subscript="max">c̅</ml:id>
												<ml:program>
													<ml:ifThen>
														<ml:apply>
															<ml:equal/>
															<ml:id xml:space="preserve">cool</ml:id>
															<ml:real>1</ml:real>
														</ml:apply>
														<ml:apply>
															<ml:id xml:space="preserve">mean</ml:id>
															<ml:sequence>
																<ml:real>0.2</ml:real>
																<ml:real>0.22</ml:real>
															</ml:sequence>
														</ml:apply>
													</ml:ifThen>
													<ml:otherwise>
														<ml:apply>
															<ml:id xml:space="preserve">mean</ml:id>
															<ml:sequence>
																<ml:real>0.1</ml:real>
																<ml:real>0.12</ml:real>
															</ml:sequence>
														</ml:apply>
													</ml:otherwise>
												</ml:program>
											</ml:localDefine>
										</ml:ifThen>
										<ml:otherwise>
											<ml:id xml:space="preserve" subscript="max">c̅</ml:id>
										</ml:otherwise>
									</ml:program>
								</ml:localDefine>
								<ml:apply>
									<ml:mult/>
									<ml:apply>
										<ml:mult/>
										<ml:apply>
											<ml:mult/>
											<ml:program>
												<ml:ifThen>
													<ml:apply>
														<ml:equal/>
														<ml:id xml:space="preserve">type</ml:id>
														<ml:str xml:space="preserve">СА</ml:str>
													</ml:apply>
													<ml:real>0.45</ml:real>
												</ml:ifThen>
												<ml:ifThen>
													<ml:apply>
														<ml:equal/>
														<ml:id xml:space="preserve">type</ml:id>
														<ml:str xml:space="preserve">РК</ml:str>
													</ml:apply>
													<ml:real>0.6</ml:real>
