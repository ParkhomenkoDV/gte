				<region region-id="544439" left="6" top="9441" width="389.25" height="31.5" align-x="68.25" align-y="9450" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
