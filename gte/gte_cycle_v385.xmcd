				<region region-id="530308" left="696" top="8781" width="327" height="261" align-x="784.5" align-y="8790" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="сжимаемость">ξ</ml:id>
