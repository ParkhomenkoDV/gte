				<region region-id="509226" left="96" top="4731.75" width="123" height="60.75" align-x="140.25" align-y="4764" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
