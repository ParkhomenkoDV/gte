				<region region-id="509222" left="156" top="4653.75" width="127.5" height="59.25" align-x="201.75" align-y="4686" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
