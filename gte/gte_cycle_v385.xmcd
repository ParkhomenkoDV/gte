							</ml:function>
							<ml:program>
								<ml:localDefine>
									<ml:id xml:space="preserve" subscript="опт">λ</ml:id>
									<ml:program>
										<ml:ifThen>
											<ml:apply>
												<ml:equal/>
												<ml:id xml:space="preserve">type</ml:id>
												<ml:str xml:space="preserve">СА</ml:str>
