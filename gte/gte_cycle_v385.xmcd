																			<ml:pow/>
																			<ml:id xml:space="preserve">π*</ml:id>
																			<ml:apply>
																				<ml:div/>
																				<ml:apply>
																					<ml:minus/>
																					<ml:real font="0">1</ml:real>
																					<ml:id xml:space="preserve">k</ml:id>
																				</ml:apply>
																				<ml:id xml:space="preserve">k</ml:id>
																			</ml:apply>
																		</ml:apply>
																		<ml:real>1</ml:real>
																	</ml:apply>
																</ml:parens>
															</ml:apply>
															<ml:real>1</ml:real>
														</ml:apply>
													</ml:apply>
													<ml:apply>
														<ml:id xml:space="preserve">ln</ml:id>
														<ml:id xml:space="preserve">π*</ml:id>
													</ml:apply>
