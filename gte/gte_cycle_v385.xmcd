													</ml:apply>
												</ml:parens>
											</ml:apply>
											<ml:matrix rows="2" cols="1">
												<ml:real>0.3</ml:real>
												<ml:real>-0.015</ml:real>
											</ml:matrix>
										</ml:ifThen>
										<ml:ifThen>
											<ml:apply>
												<ml:and/>
												<ml:parens>
													<ml:apply>
														<ml:equal/>
														<ml:id xml:space="preserve">type</ml:id>
														<ml:str xml:space="preserve">РК</ml:str>
													</ml:apply>
												</ml:parens>
												<ml:parens>
													<ml:apply>
														<ml:greaterThan/>
														<ml:apply>
															<ml:div/>
															<ml:id xml:space="preserve">λ</ml:id>
															<ml:id xml:space="preserve" subscript="опт">λ</ml:id>
														</ml:apply>
