					<ml:id xml:space="preserve" subscript="к.л">ξ</ml:id>
					<ml:eval placeholderMultiplicationStyle="default">
						<ml:symEval style="default" hide-keywords="true" hide-lhs="false">
							<ml:apply>
								<ml:div/>
								<ml:apply>
									<ml:mult/>
									<ml:apply>
										<ml:mult/>
										<ml:apply>
											<ml:mult/>
											<ml:real>2</ml:real>
											<ml:id xml:space="preserve" subscript="тр.л">ξ</ml:id>
										</ml:apply>
										<ml:id xml:space="preserve" subscript="л">t</ml:id>
