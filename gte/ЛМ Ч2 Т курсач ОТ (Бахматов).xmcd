		<region region-id="5458" left="6" top="21810" width="330.75" height="15" align-x="21.75" align-y="21822" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Течение дозвуковое. Учетволновых потерь не требуется.</p>
			</text>
		</region>
		<region region-id="5459" left="6" top="21840" width="214.5" height="15" align-x="9" align-y="21852" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">6. Определим учет концевых потерь.</p>
			</text>
		</region>
		<region region-id="5460" left="6" top="21860.25" width="458.25" height="38.25" align-x="32.25" align-y="21882" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<math optimize="false" disable-calc="false">
