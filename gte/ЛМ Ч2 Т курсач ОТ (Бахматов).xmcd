		<region region-id="5461" left="6" top="21906" width="318" height="15" align-x="29.25" align-y="21918" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">7. Определим коэффициент потерь в рабочей лопатке:</p>
			</text>
		</region>
		<region region-id="5462" left="6" top="21919.5" width="258" height="23.25" align-x="25.5" align-y="21936" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
