		<region region-id="4150" left="6" top="4449" width="471" height="46.5" align-x="31.5" align-y="4476" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<math optimize="false" disable-calc="false">
				<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
					<ml:id xml:space="preserve" subscript="у1">T</ml:id>
					<ml:eval placeholderMultiplicationStyle="default">
						<ml:symEval style="equals" hide-keywords="true" hide-lhs="false">
							<ml:apply>
								<ml:minus/>
								<ml:id xml:space="preserve" subscript="г">T*</ml:id>
								<ml:apply>
									<ml:div/>
									<ml:apply>
										<ml:mult/>
										<ml:id xml:space="preserve" subscript="1тк">H</ml:id>
										<ml:apply>
											<ml:pow/>
											<ml:id xml:space="preserve" subscript="1">φ</ml:id>
											<ml:real>2</ml:real>
										</ml:apply>
									</ml:apply>
