		</region>
		<region region-id="4066" left="504" top="6" width="75" height="16.5" align-x="561" align-y="18" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
			<math optimize="false" disable-calc="false">
				<ml:define warning="WarnRedefinedUDScalar" xmlns:ml="http://schemas.mathsoft.com/math30">
