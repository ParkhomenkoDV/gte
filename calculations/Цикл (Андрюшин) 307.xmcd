				<region region-id="426377" left="6" top="6473.25" width="462.75" height="159" align-x="124.5" align-y="6498" show-border="true" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="гор.ср">Cp</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve" subscript="1">P</ml:id>
									<ml:id xml:space="preserve" subscript="2">P</ml:id>
									<ml:id xml:space="preserve" subscript="1">T</ml:id>
									<ml:id xml:space="preserve" subscript="2">T</ml:id>
									<ml:id xml:space="preserve">Fuel</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:ifThen>
									<ml:apply>
										<ml:and/>
										<ml:parens>
											<ml:apply>
												<ml:notEqual/>
												<ml:id xml:space="preserve" subscript="1">P</ml:id>
												<ml:id xml:space="preserve" subscript="2">P</ml:id>
											</ml:apply>
										</ml:parens>
										<ml:parens>
											<ml:apply>
												<ml:notEqual/>
												<ml:id xml:space="preserve" subscript="1">T</ml:id>
												<ml:id xml:space="preserve" subscript="2">T</ml:id>
											</ml:apply>
										</ml:parens>
									</ml:apply>
									<ml:apply>
										<ml:mult/>
										<ml:apply>
											<ml:mult/>
											<ml:apply>
												<ml:div/>
												<ml:real>1</ml:real>
												<ml:apply>
													<ml:minus/>
													<ml:id xml:space="preserve" subscript="2">P</ml:id>
													<ml:id xml:space="preserve" subscript="1">P</ml:id>
												</ml:apply>
											</ml:apply>
											<ml:apply>
												<ml:div/>
												<ml:real>1</ml:real>
												<ml:apply>
