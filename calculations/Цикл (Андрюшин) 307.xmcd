					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Теплоемкость чистых продуктов сгорания при α=1 (Дж/кг/К):</p>
					</text>
				</region>
				<region region-id="426427" left="6" top="4683" width="336.75" height="123" align-x="78.75" align-y="4692" show-border="true" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="ч.г">Cp</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">P</ml:id>
									<ml:id xml:space="preserve">T</ml:id>
									<ml:id xml:space="preserve">Fuel</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:ifThen>
									<ml:apply>
										<ml:or/>
										<ml:parens>
											<ml:apply>
												<ml:equal/>
												<ml:id xml:space="preserve">Fuel</ml:id>
												<ml:str xml:space="preserve">Керосин</ml:str>
											</ml:apply>
										</ml:parens>
										<ml:parens>
											<ml:apply>
												<ml:equal/>
												<ml:id xml:space="preserve">Fuel</ml:id>
												<ml:str xml:space="preserve">Бензин</ml:str>
											</ml:apply>
										</ml:parens>
									</ml:apply>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="ч.керосин">Cp</ml:id>
										<ml:id xml:space="preserve">T</ml:id>
									</ml:apply>
								</ml:ifThen>
								<ml:ifThen>
									<ml:parens>
										<ml:apply>
											<ml:equal/>
											<ml:id xml:space="preserve">Fuel</ml:id>
											<ml:str xml:space="preserve">Дизель</ml:str>
										</ml:apply>
									</ml:parens>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="ч.дизель">Cp</ml:id>
										<ml:id xml:space="preserve">T</ml:id>
									</ml:apply>
								</ml:ifThen>
								<ml:ifThen>
									<ml:parens>
										<ml:apply>
											<ml:equal/>
											<ml:id xml:space="preserve">Fuel</ml:id>
											<ml:str xml:space="preserve">Мазут</ml:str>
										</ml:apply>
									</ml:parens>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="ч.мазут">Cp</ml:id>
										<ml:id xml:space="preserve">T</ml:id>
									</ml:apply>
								</ml:ifThen>
								<ml:ifThen>
									<ml:parens>
										<ml:apply>
											<ml:equal/>
											<ml:id xml:space="preserve">Fuel</ml:id>
											<ml:str xml:space="preserve">Природный газ</ml:str>
										</ml:apply>
									</ml:parens>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="ч.пг">Cp</ml:id>
										<ml:id xml:space="preserve">T</ml:id>
									</ml:apply>
								</ml:ifThen>
								<ml:ifThen>
									<ml:parens>
										<ml:apply>
											<ml:equal/>
											<ml:id xml:space="preserve">Fuel</ml:id>
											<ml:str xml:space="preserve">Коксовый газ</ml:str>
										</ml:apply>
