					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="НВД">N</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:program>
									<ml:apply>
										<ml:mult/>
										<ml:parens>
											<ml:apply>
												<ml:plus/>
												<ml:apply>
													<ml:plus/>
													<ml:real>50</ml:real>
													<ml:real>100</ml:real>
												</ml:apply>
