										</ml:parens>
										<ml:apply>
											<ml:pow/>
											<ml:real>10</ml:real>
											<ml:real>3</ml:real>
										</ml:apply>
									</ml:apply>
									<ml:ifThen>
										<ml:apply>
											<ml:equal/>
											<ml:id xml:space="preserve" subscript="ВД">Н</ml:id>
											<ml:real>0</ml:real>
										</ml:apply>
										<ml:real>0</ml:real>
									</ml:ifThen>
								</ml:program>
								<ml:unitOverride>
									<ml:apply>
										<ml:pow/>
										<ml:real>10</ml:real>
										<ml:real>3</ml:real>
									</ml:apply>
								</ml:unitOverride>
