				<region region-id="5090" left="12" top="2226.75" width="188.25" height="14.25" align-x="12" align-y="2238" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Обычный" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">Эффективность пленки</p>
					</text>
				</region>
				<region region-id="5091" left="12" top="2250.75" width="201" height="64.5" align-x="51.75" align-y="2262" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="к5">θ</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">x</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:ifThen>
									<ml:apply>
										<ml:lessOrEqual/>
										<ml:id xml:space="preserve">x</ml:id>
										<ml:id xml:space="preserve" subscript="н.к5">x</ml:id>
									</ml:apply>
									<ml:real>1</ml:real>
								</ml:ifThen>
								<ml:ifThen>
									<ml:apply>
										<ml:lessOrEqual/>
										<ml:apply>
											<ml:lessThan/>
											<ml:id xml:space="preserve" subscript="н.к5">x</ml:id>
											<ml:id xml:space="preserve">x</ml:id>
										</ml:apply>
										<ml:id xml:space="preserve" subscript="п.к5">x</ml:id>
									</ml:apply>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="п.к5">θ</ml:id>
										<ml:id xml:space="preserve">x</ml:id>
									</ml:apply>
								</ml:ifThen>
								<ml:otherwise>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="o.к5">θ</ml:id>
										<ml:id xml:space="preserve">x</ml:id>
									</ml:apply>
								</ml:otherwise>
							</ml:program>
						</ml:define>
					</math>
				</region>
				<region region-id="9669" left="6" top="2322.75" width="306.75" height="14.25" align-x="31.5" align-y="2334" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Температура пленки в конце<sp count="2"/>участка:</p>
					</text>
				</region>
				<region region-id="9670" left="6" top="2346.75" width="374.25" height="18" align-x="38.25" align-y="2358" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="п.к5">T</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:apply>
									<ml:minus/>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="п.к4">T</ml:id>
										<ml:id xml:space="preserve" subscript="кон.к3">x</ml:id>
									</ml:apply>
									<ml:apply>
										<ml:mult/>
										<ml:apply>
											<ml:id xml:space="preserve" subscript="к5">θ</ml:id>
											<ml:id xml:space="preserve" subscript="кон.к5">x</ml:id>
										</ml:apply>
										<ml:parens>
											<ml:apply>
												<ml:minus/>
												<ml:apply>
													<ml:id xml:space="preserve" subscript="п.к4">T</ml:id>
													<ml:id xml:space="preserve" subscript="кон.к5">x</ml:id>
												</ml:apply>
												<ml:id xml:space="preserve" subscript="охл.5.t">T*</ml:id>
											</ml:apply>
										</ml:parens>
									</ml:apply>
								</ml:apply>
								<result xmlns="http://schemas.mathsoft.com/math30">
									<ml:real>1072.6813513120137</ml:real>
								</result>
							</ml:eval>
						</ml:define>
						<resultFormat numeric-only="true">
							<general precision="1" show-trailing-zeros="false" radix="dec" complex-threshold="10" zero-threshold="15" imaginary-value="i" exponential-threshold="4"/>
							<matrix display-style="auto" expand-nested-arrays="false"/>
							<unit format-units="false" simplify-units="false" fractional-unit-exponent="false"/>
						</resultFormat>
					</math>
				</region>
				<region region-id="9671" left="6" top="2370.75" width="270" height="14.25" align-x="19.5" align-y="2382" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Расход воздуха через отверстия ряда:</p>
					</text>
				</region>
				<region region-id="9663" left="6" top="2397" width="235.5" height="41.25" align-x="32.25" align-y="2424" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="к5">G</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:apply>
									<ml:mult/>
									<ml:apply>
										<ml:mult/>
										<ml:apply>
											<ml:mult/>
											<ml:id xml:space="preserve" subscript="отв.к5">N</ml:id>
											<ml:apply>
												<ml:div/>
												<ml:apply>
													<ml:mult/>
													<ml:id xml:space="preserve">π</ml:id>
													<ml:apply>
														<ml:pow/>
														<ml:id xml:space="preserve" subscript="к.5">d</ml:id>
														<ml:real>2</ml:real>
													</ml:apply>
												</ml:apply>
												<ml:real>4</ml:real>
											</ml:apply>
										</ml:apply>
										<ml:id xml:space="preserve" subscript="в5к">ρ</ml:id>
									</ml:apply>
									<ml:id xml:space="preserve" subscript="в.к.5">u</ml:id>
								</ml:apply>
								<result xmlns="http://schemas.mathsoft.com/math30">
									<ml:real>0.0090414775203238543</ml:real>
								</result>
							</ml:eval>
						</ml:define>
					</math>
				</region>
				<region region-id="9664" left="6" top="2448.75" width="68.25" height="18" align-x="30.75" align-y="2460" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:eval placeholderMultiplicationStyle="default" xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="к4">G</ml:id>
							<result xmlns="http://schemas.mathsoft.com/math30">
								<ml:real>0.0085762623973109284</ml:real>
							</result>
						</ml:eval>
					</math>
				</region>
				<region region-id="9665" left="114" top="2448.75" width="33.75" height="14.25" align-x="117.75" align-y="2460" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">кг/с</p>
					</text>
				</region>
				<region region-id="9656" left="6" top="2472.75" width="440.25" height="14.25" align-x="28.5" align-y="2484" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Отношение расхода воздуха к суммарному расходу охлаждающего воздуха:</p>
					</text>
				</region>
				<region region-id="9651" left="6" top="2489.25" width="157.5" height="41.25" align-x="126" align-y="2514" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:eval placeholderMultiplicationStyle="default" xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:symEval style="equals" hide-keywords="true" hide-lhs="false">
								<ml:apply>
									<ml:div/>
									<ml:id xml:space="preserve" subscript="к5">G</ml:id>
									<ml:id xml:space="preserve" subscript="1">ΔG</ml:id>
								</ml:apply>
								<ml:command>
									<ml:sequence>
										<ml:id xml:space="preserve">explicit</ml:id>
										<ml:id xml:space="preserve">ALL</ml:id>
									</ml:sequence>
								</ml:command>
								<ml:symResult>
									<ml:apply>
										<ml:div/>
										<ml:apply>
											<ml:mult style="auto-select"/>
											<ml:real>9.041</ml:real>
											<ml:apply>
												<ml:pow/>
												<ml:real>10</ml:real>
												<ml:real>-3</ml:real>
											</ml:apply>
										</ml:apply>
										<ml:real>0.152</ml:real>
									</ml:apply>
								</ml:symResult>
							</ml:symEval>
							<result xmlns="http://schemas.mathsoft.com/math30">
								<ml:real>0.059658993883019</ml:real>
							</result>
						</ml:eval>
						<resultFormat numeric-only="false">
							<general precision="3" show-trailing-zeros="false" radix="dec" complex-threshold="10" zero-threshold="15" imaginary-value="i" exponential-threshold="3"/>
							<matrix display-style="auto" expand-nested-arrays="false"/>
							<unit format-units="false" simplify-units="false" fractional-unit-exponent="false"/>
						</resultFormat>
					</math>
				</region>
				<region region-id="9652" left="6" top="2532.75" width="159.75" height="14.25" align-x="38.25" align-y="2544" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Обычный" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Температура пленки по участку</p>
					</text>
				</region>
				<region region-id="9653" left="6" top="2550.75" width="342.75" height="18" align-x="53.25" align-y="2562" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="п.к5">T</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">x</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:apply>
								<ml:minus/>
								<ml:apply>
									<ml:id xml:space="preserve" subscript="п.к4">T</ml:id>
									<ml:apply>
										<ml:plus/>
										<ml:id xml:space="preserve">x</ml:id>
										<ml:id xml:space="preserve" subscript="кон.к4">x</ml:id>
									</ml:apply>
								</ml:apply>
								<ml:apply>
									<ml:mult/>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="к5">θ</ml:id>
										<ml:id xml:space="preserve">x</ml:id>
									</ml:apply>
									<ml:parens>
										<ml:apply>
											<ml:minus/>
											<ml:apply>
												<ml:id xml:space="preserve" subscript="п.к4">T</ml:id>
												<ml:apply>
													<ml:plus/>
													<ml:id xml:space="preserve">x</ml:id>
													<ml:id xml:space="preserve" subscript="кон.к4">x</ml:id>
												</ml:apply>
											</ml:apply>
											<ml:id xml:space="preserve" subscript="охл.5.t">T*</ml:id>
										</ml:apply>
									</ml:parens>
								</ml:apply>
							</ml:apply>
						</ml:define>
					</math>
				</region>
