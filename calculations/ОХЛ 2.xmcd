					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Обычный" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">Эффективность пленки</p>
					</text>
				</region>
				<region region-id="1480" left="6" top="2244.75" width="201" height="64.5" align-x="45.75" align-y="2256" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="к3">θ</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">x</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:ifThen>
									<ml:apply>
										<ml:lessOrEqual/>
										<ml:id xml:space="preserve">x</ml:id>
										<ml:id xml:space="preserve" subscript="n.к3">x</ml:id>
									</ml:apply>
									<ml:real>1</ml:real>
								</ml:ifThen>
								<ml:ifThen>
									<ml:apply>
										<ml:lessOrEqual/>
										<ml:apply>
											<ml:lessThan/>
											<ml:id xml:space="preserve" subscript="n.к3">x</ml:id>
											<ml:id xml:space="preserve">x</ml:id>
										</ml:apply>
										<ml:id xml:space="preserve" subscript="p.к3">x</ml:id>
									</ml:apply>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="п.к3">θ</ml:id>
										<ml:id xml:space="preserve">x</ml:id>
									</ml:apply>
								</ml:ifThen>
								<ml:otherwise>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="o.к3">θ</ml:id>
										<ml:id xml:space="preserve">x</ml:id>
									</ml:apply>
								</ml:otherwise>
							</ml:program>
						</ml:define>
					</math>
				</region>
				<region region-id="1481" left="6" top="2316.75" width="306.75" height="14.25" align-x="31.5" align-y="2328" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Температура пленки в конце<sp count="2"/>участка:</p>
					</text>
				</region>
				<region region-id="1482" left="6" top="2340.75" width="374.25" height="18" align-x="38.25" align-y="2352" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="п.к3">T</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:apply>
									<ml:minus/>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="п.к2">T</ml:id>
										<ml:id xml:space="preserve" subscript="кон.к3">x</ml:id>
									</ml:apply>
									<ml:apply>
										<ml:mult/>
										<ml:apply>
											<ml:id xml:space="preserve" subscript="к3">θ</ml:id>
											<ml:id xml:space="preserve" subscript="кон.к3">x</ml:id>
										</ml:apply>
										<ml:parens>
											<ml:apply>
												<ml:minus/>
												<ml:apply>
													<ml:id xml:space="preserve" subscript="п.к2">T</ml:id>
													<ml:id xml:space="preserve" subscript="кон.к3">x</ml:id>
												</ml:apply>
												<ml:id xml:space="preserve" subscript="охл.3.t">T*</ml:id>
											</ml:apply>
										</ml:parens>
									</ml:apply>
								</ml:apply>
								<result xmlns="http://schemas.mathsoft.com/math30">
									<ml:real>1130.9019522579035</ml:real>
								</result>
							</ml:eval>
						</ml:define>
						<resultFormat numeric-only="true">
							<general precision="1" show-trailing-zeros="false" radix="dec" complex-threshold="10" zero-threshold="15" imaginary-value="i" exponential-threshold="4"/>
							<matrix display-style="auto" expand-nested-arrays="false"/>
							<unit format-units="false" simplify-units="false" fractional-unit-exponent="false"/>
						</resultFormat>
