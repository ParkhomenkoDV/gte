				<region region-id="1097" left="6" top="2172.75" width="201" height="64.5" align-x="45.75" align-y="2184" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="с5">θ</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">x</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:ifThen>
									<ml:apply>
										<ml:lessOrEqual/>
										<ml:id xml:space="preserve">x</ml:id>
										<ml:id xml:space="preserve" subscript="n.s5">x</ml:id>
									</ml:apply>
									<ml:real>1</ml:real>
								</ml:ifThen>
								<ml:ifThen>
									<ml:apply>
										<ml:lessOrEqual/>
										<ml:apply>
											<ml:lessThan/>
											<ml:id xml:space="preserve" subscript="n.s5">x</ml:id>
											<ml:id xml:space="preserve">x</ml:id>
										</ml:apply>
										<ml:id xml:space="preserve" subscript="p.s5">x</ml:id>
									</ml:apply>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="п.s5">θ</ml:id>
										<ml:id xml:space="preserve">x</ml:id>
									</ml:apply>
								</ml:ifThen>
								<ml:otherwise>
									<ml:apply>
										<ml:id xml:space="preserve" subscript="o.s5">θ</ml:id>
										<ml:id xml:space="preserve">x</ml:id>
									</ml:apply>
								</ml:otherwise>
							</ml:program>
						</ml:define>
