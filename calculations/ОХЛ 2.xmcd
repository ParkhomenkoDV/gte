				<region region-id="9337" left="12" top="2388.75" width="270" height="14.25" align-x="25.5" align-y="2400" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Расход воздуха через отверстия ряда:</p>
					</text>
				</region>
				<region region-id="9338" left="6" top="2409" width="235.5" height="41.25" align-x="32.25" align-y="2436" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="к4">G</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:apply>
									<ml:mult/>
									<ml:apply>
										<ml:mult/>
										<ml:apply>
											<ml:mult/>
											<ml:id xml:space="preserve" subscript="отв.к4">N</ml:id>
											<ml:apply>
												<ml:div/>
												<ml:apply>
													<ml:mult/>
													<ml:id xml:space="preserve">π</ml:id>
													<ml:apply>
														<ml:pow/>
														<ml:id xml:space="preserve" subscript="к.4">d</ml:id>
														<ml:real>2</ml:real>
													</ml:apply>
												</ml:apply>
												<ml:real>4</ml:real>
											</ml:apply>
										</ml:apply>
										<ml:id xml:space="preserve" subscript="в4к">ρ</ml:id>
									</ml:apply>
									<ml:id xml:space="preserve" subscript="в.к.4">u</ml:id>
								</ml:apply>
								<result xmlns="http://schemas.mathsoft.com/math30">
									<ml:real>0.0085762623973109284</ml:real>
								</result>
							</ml:eval>
						</ml:define>
					</math>
				</region>
				<region region-id="9307" left="6" top="2466.75" width="68.25" height="18" align-x="30.75" align-y="2478" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:eval placeholderMultiplicationStyle="default" xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="к4">G</ml:id>
							<result xmlns="http://schemas.mathsoft.com/math30">
