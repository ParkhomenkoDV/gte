				<region region-id="518028" left="234" top="606.75" width="150" height="78.75" align-x="274.5" align-y="618" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#80ffff" tag="">
					<math optimize="false" disable-calc="false">
