										</ml:apply>
										<ml:apply>
											<ml:minus/>
											<ml:real>1</ml:real>
											<ml:apply>
												<ml:mult/>
												<ml:real>1.42</ml:real>
												<ml:parens>
													<ml:apply>
														<ml:div/>
														<ml:apply>
															<ml:minus/>
