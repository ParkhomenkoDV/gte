					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Ср. теплоемкость чистых продуктов сгорания при α=1 (Дж/кг/К):</p>
					</text>
				</region>
				<region region-id="426503" left="6" top="4895.25" width="459.75" height="159" align-x="123" align-y="4920" show-border="true" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="ч.г.ср">Cp</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve" subscript="1">P</ml:id>
									<ml:id xml:space="preserve" subscript="2">P</ml:id>
									<ml:id xml:space="preserve" subscript="1">T</ml:id>
									<ml:id xml:space="preserve" subscript="2">T</ml:id>
									<ml:id xml:space="preserve">Fuel</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:ifThen>
									<ml:apply>
										<ml:and/>
										<ml:parens>
											<ml:apply>
												<ml:notEqual/>
												<ml:id xml:space="preserve" subscript="1">P</ml:id>
												<ml:id xml:space="preserve" subscript="2">P</ml:id>
											</ml:apply>
										</ml:parens>
										<ml:parens>
											<ml:apply>
												<ml:notEqual/>
												<ml:id xml:space="preserve" subscript="1">T</ml:id>
												<ml:id xml:space="preserve" subscript="2">T</ml:id>
											</ml:apply>
										</ml:parens>
									</ml:apply>
									<ml:apply>
										<ml:mult/>
										<ml:apply>
											<ml:mult/>
											<ml:apply>
												<ml:div/>
												<ml:real>1</ml:real>
												<ml:apply>
													<ml:minus/>
													<ml:id xml:space="preserve" subscript="2">P</ml:id>
													<ml:id xml:space="preserve" subscript="1">P</ml:id>
												</ml:apply>
											</ml:apply>
											<ml:apply>
												<ml:div/>
												<ml:real>1</ml:real>
												<ml:apply>
													<ml:minus/>
													<ml:id xml:space="preserve" subscript="2">T</ml:id>
													<ml:id xml:space="preserve" subscript="1">T</ml:id>
												</ml:apply>
											</ml:apply>
										</ml:apply>
										<ml:apply>
											<ml:integral auto-algorithm="true" algorithm="adaptive"/>
											<ml:lambda>
												<ml:boundVars>
													<ml:id xml:space="preserve">P</ml:id>
												</ml:boundVars>
												<ml:apply>
