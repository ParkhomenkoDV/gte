															<ml:id xml:space="preserve" subscript="КС1">T</ml:id>
														</ml:apply>
													</ml:apply>
												</ml:parens>
											</ml:apply>
										</ml:apply>
									</ml:apply>
								</ml:localDefine>
								<ml:ifThen>
									<ml:apply>
										<ml:or/>
										<ml:apply>
											<ml:lessThan/>
											<ml:id xml:space="preserve">g</ml:id>
											<ml:real>0</ml:real>
										</ml:apply>
										<ml:apply>
											<ml:greaterThan/>
											<ml:id xml:space="preserve">g</ml:id>
											<ml:real>1</ml:real>
										</ml:apply>
									</ml:apply>
