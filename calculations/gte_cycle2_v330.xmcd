					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="(b/t)=1">ε</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve" subscript="2(b/t)=1">β</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:ifThen>
									<ml:apply>
										<ml:lessOrEqual/>
										<ml:apply>
											<ml:lessOrEqual/>
											<ml:real>30</ml:real>
											<ml:id xml:space="preserve" subscript="2(b/t)=1">β</ml:id>
										</ml:apply>
										<ml:real>60</ml:real>
									</ml:apply>
									<ml:parens>
										<ml:apply>
											<ml:plus/>
											<ml:apply>
												<ml:minus/>
												<ml:apply>
													<ml:mult/>
													<ml:real>0.005</ml:real>
													<ml:apply>
														<ml:pow/>
														<ml:id xml:space="preserve" subscript="2(b/t)=1">β</ml:id>
														<ml:real font="0">2</ml:real>
													</ml:apply>
												</ml:apply>
												<ml:apply>
													<ml:mult/>
													<ml:real>0.05</ml:real>
													<ml:id xml:space="preserve" subscript="2(b/t)=1">β</ml:id>
												</ml:apply>
											</ml:apply>
											<ml:real>5</ml:real>
										</ml:apply>
									</ml:parens>
								</ml:ifThen>
								<ml:ifThen>
									<ml:apply>
										<ml:lessOrEqual/>
										<ml:apply>
											<ml:lessThan/>
											<ml:real>60</ml:real>
											<ml:id xml:space="preserve" subscript="2(b/t)=1">β</ml:id>
										</ml:apply>
										<ml:real>120</ml:real>
									</ml:apply>
									<ml:apply>
										<ml:minus/>
										<ml:apply>
											<ml:plus/>
											<ml:apply>
												<ml:mult/>
												<ml:real>-0.0016</ml:real>
												<ml:apply>
													<ml:pow/>
													<ml:id xml:space="preserve" subscript="2(b/t)=1">β</ml:id>
													<ml:real font="0">2</ml:real>
												</ml:apply>
											</ml:apply>
											<ml:apply>
												<ml:mult/>
												<ml:real>0.7031</ml:real>
												<ml:id xml:space="preserve" subscript="2(b/t)=1">β</ml:id>
											</ml:apply>
										</ml:apply>
										<ml:real>16.646</ml:real>
									</ml:apply>
								</ml:ifThen>
							</ml:program>
						</ml:define>
					</math>
